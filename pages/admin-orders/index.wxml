<view class="container">

  <!-- Topbar -->
  <view class="topbar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">‹</text>
    </view>
    <text class="topbar-title">Review orders</text>
    <view style="width:60rpx;"></view>
  </view>

  <!-- Filter Tabs -->
  <view class="filter-tabs">
    <view class="filter-tab {{filter === 'pending' ? 'filter-tab-active' : ''}}" bindtap="setFilter" data-filter="pending">
      <text class="filter-tab-text {{filter === 'pending' ? 'filter-tab-text-active' : ''}}">Pending</text>
      <view wx:if="{{pendingCount > 0}}" class="filter-badge">{{pendingCount}}</view>
    </view>
    <view class="filter-tab {{filter === 'approved' ? 'filter-tab-active' : ''}}" bindtap="setFilter" data-filter="approved">
      <text class="filter-tab-text {{filter === 'approved' ? 'filter-tab-text-active' : ''}}">Approved</text>
    </view>
    <view class="filter-tab {{filter === 'rejected' ? 'filter-tab-active' : ''}}" bindtap="setFilter" data-filter="rejected">
      <text class="filter-tab-text {{filter === 'rejected' ? 'filter-tab-text-active' : ''}}">Rejected</text>
    </view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:elif="{{orders.length === 0}}">
      <view class="empty-wrap">
        <text class="empty-text">No {{filter}} orders</text>
      </view>
    </block>

    <block wx:else>
      <view wx:for="{{orders}}" wx:key="id" class="order-card">

        <!-- Header: avatar + name + badge -->
        <view class="order-header">
          <view class="avatar">
            <text class="avatar-icon">👤</text>
          </view>
          <view class="order-header-body">
            <text class="order-name">{{item.name}}</text>
            <text class="order-plan">{{item.plan_name}}</text>
          </view>
          <view class="status-badge status-{{item.status}}">
            <text class="status-text">{{item.status}}</text>
          </view>
        </view>

        <!-- Info rows -->
        <view class="order-divider"></view>

        <view class="info-row">
          <text class="info-icon">📍</text>
          <text class="info-val">{{item.address}}, {{item.district}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">📱</text>
          <text class="info-val">{{item.phone}}</text>
        </view>
        <view class="info-row" wx:if="{{item.allergies}}">
          <text class="info-icon">⚠️</text>
          <text class="info-val info-warning">{{item.allergies}}</text>
        </view>

        <!-- Actions -->
        <view wx:if="{{item.status === 'pending'}}" class="order-actions">
          <button class="btn-reject" catchtap="rejectOrder" data-id="{{item.id}}">
            <text>✕</text><text>  Reject</text>
          </button>
          <button class="btn-approve" catchtap="approveOrder" data-id="{{item.id}}">
            <text>✓</text><text>  Approve</text>
          </button>
        </view>

      </view>
    </block>

  </scroll-view>

  <!-- Rejection Modal -->
  <view class="modal-overlay {{showRejectModal ? 'modal-visible' : ''}}" bindtap="closeModal">
    <view class="modal" catchtap="noop">
      <text class="modal-title">Reason for rejection</text>
      <textarea
        class="modal-input"
        placeholder="e.g. Outside delivery area, will expand soon..."
        value="{{rejectionNote}}"
        bindinput="onRejectNoteInput"
        auto-height
      />
      <view class="modal-actions">
        <button class="modal-btn-cancel" bindtap="closeModal">Cancel</button>
        <button class="modal-btn-confirm" bindtap="confirmReject">Send rejection</button>
      </view>
    </view>
  </view>

</view>
