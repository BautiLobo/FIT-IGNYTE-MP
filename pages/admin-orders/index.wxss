/* pages/admin-orders/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; }

/* ── TOPBAR ── */
.topbar { background:#0b0b0c; padding:80rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:60rpx; height:60rpx; background:#1a1a22; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-arrow { font-size:36rpx; color:#f3f3f4; font-weight:300; }
.topbar-title { flex:1; text-align:center; font-size:32rpx; font-weight:800; color:#f3f3f4; }

/* ── FILTER TABS ── */
.filter-tabs { display:flex; background:#0b0b0c; border-bottom:1rpx solid #1a1a22; flex-shrink:0; }
.filter-tab { flex:1; padding:24rpx 0 20rpx; text-align:center; display:flex; align-items:center; justify-content:center; gap:10rpx; position:relative; }
.filter-tab-active { border-bottom:3rpx solid #e8342a; }
.filter-tab-text { font-size:28rpx; font-weight:600; color:#5d5d65; }
.filter-tab-text-active { color:#e8342a; }
.filter-badge { background:#e8342a; color:#fff; font-size:20rpx; font-weight:800; padding:2rpx 12rpx; border-radius:20rpx; }

/* ── SCROLL ── */
.scroll { flex:1; padding:24rpx 24rpx; }
.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a33; border-top-color:#e8342a; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }
.empty-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.empty-text { font-size:28rpx; color:#3a3a45; }

/* ── ORDER CARD ── */
.order-card {
  background: #13131a;
  border: 1rpx solid #1a1a22;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

/* Header */
.order-header { display:flex; align-items:center; gap:20rpx; }
.avatar {
  width: 80rpx;
  height: 80rpx;
  background: #1a1a2a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-icon { font-size: 36rpx; }
.order-header-body { flex:1; }
.order-name { font-size: 34rpx; font-weight: 800; color: #f3f3f4; display:block; }
.order-plan { font-size: 24rpx; color: #5d5d65; display:block; margin-top:4rpx; }

/* Status badge */
.status-badge { padding: 8rpx 18rpx; border-radius: 20rpx; }
.status-pending { background:#1a1200; }
.status-approved { background:#052e16; }
.status-rejected { background:#1a0808; }
.status-text { font-size: 20rpx; font-weight: 700; }
.status-pending .status-text { color:#d97706; }
.status-approved .status-text { color:#4ade80; }
.status-rejected .status-text { color:#f87171; }

/* Divider */
.order-divider { height:1rpx; background:#1a1a22; margin:20rpx 0; }

/* Info rows */
.info-row { display:flex; align-items:flex-start; gap:16rpx; margin-bottom:16rpx; }
.info-icon { font-size:28rpx; flex-shrink:0; width:40rpx; }
.info-val { font-size:28rpx; color:#c0c0cc; flex:1; line-height:1.5; }
.info-warning { color:#d97706; }

/* Action buttons */
.order-actions { display:flex; gap:16rpx; margin-top:24rpx; }
.btn-reject {
  flex:1;
  background: transparent;
  border: 2rpx solid #3a1010;
  color: #f87171;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}
.btn-approve {
  flex: 1.4;
  background: #e8342a;
  border: none;
  color: #fff;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

/* ── MODAL ── */
.modal-overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.75); display:none; align-items:flex-end; justify-content:center; z-index:100; }
.modal-visible { display:flex; }
.modal { background:#1a1a22; border-radius:30rpx 30rpx 0 0; padding:36rpx 28rpx 64rpx; width:100%; }
.modal-title { font-size:32rpx; font-weight:800; color:#f3f3f4; display:block; margin-bottom:24rpx; }
.modal-input { background:#0b0b0c; border:1rpx solid #2a2a33; border-radius:16rpx; padding:20rpx; font-size:26rpx; color:#f3f3f4; width:100%; box-sizing:border-box; min-height:120rpx; margin-bottom:24rpx; }
.modal-actions { display:flex; gap:16rpx; }
.modal-btn-cancel { flex:1; background:transparent; border:1rpx solid #2a2a33; color:#5d5d65; border-radius:16rpx; padding:24rpx; font-size:28rpx; }
.modal-btn-confirm { flex:1; background:#7f1d1d; border:none; color:#f87171; border-radius:16rpx; padding:24rpx; font-size:28rpx; font-weight:700; }
