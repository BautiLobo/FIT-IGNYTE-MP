/* pages/admin-orders/index.wxss */
.container { display:flex; flex-direction:column; height:100vh; background:#0d0d0d; }
.topbar { background:#111; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:60rpx; }
.back-arrow { font-size:48rpx; color:#E8342A; font-weight:300; }
.topbar-center { flex:1; text-align:center; }
.topbar-title { font-size:32rpx; font-weight:800; color:#fff; display:block; }
.topbar-right { width:60rpx; }

/* Filter Tabs */
.filter-tabs { display:flex; background:#111; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; }
.filter-tab { flex:1; padding:18rpx; text-align:center; font-size:24rpx; color:#555; font-weight:600; display:flex; align-items:center; justify-content:center; gap:8rpx; }
.filter-tab-active { color:#E8342A; border-bottom:3rpx solid #E8342A; }
.filter-badge { background:#E8342A; color:#fff; font-size:18rpx; font-weight:800; padding:2rpx 10rpx; border-radius:20rpx; }

/* Scroll */
.scroll { flex:1; padding:20rpx 24rpx; }

/* Loading / Empty */
.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a2a; border-top-color:#E8342A; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }
.empty-wrap { display:flex; flex-direction:column; align-items:center; padding:80rpx 0; gap:16rpx; }
.empty-icon { font-size:70rpx; }
.empty-text { font-size:26rpx; color:#555; }

/* Order Card */
.order-card { background:#111; border:1rpx solid #1e1e1e; border-radius:20rpx; padding:24rpx; margin-bottom:16rpx; }
.order-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14rpx; }
.order-name { font-size:30rpx; font-weight:800; color:#fff; display:block; }
.order-plan { font-size:22rpx; color:#666; display:block; margin-top:4rpx; }
.order-status-badge { font-size:20rpx; font-weight:700; padding:6rpx 16rpx; border-radius:20rpx; }
.order-status-pending { background:#1a1200; color:#f59e0b; }
.order-status-approved { background:#052e16; color:#4ade80; }
.order-status-rejected { background:#1a0808; color:#f87171; }
.order-divider { height:1rpx; background:#1a1a1a; margin-bottom:14rpx; }
.order-info-row { display:flex; gap:12rpx; margin-bottom:10rpx; align-items:flex-start; }
.order-info-label { font-size:22rpx; color:#555; flex-shrink:0; width:160rpx; }
.order-info-val { font-size:22rpx; color:#ccc; flex:1; }
.order-info-warning { color:#f59e0b; }

/* Order Actions */
.order-actions { display:flex; gap:14rpx; margin-top:20rpx; }
.btn-reject { flex:1; background:transparent; border:1rpx solid #7f1d1d; color:#f87171; border-radius:16rpx; padding:18rpx; font-size:26rpx; font-weight:700; }
.btn-approve { flex:1; background:#E8342A; border:none; color:#fff; border-radius:16rpx; padding:18rpx; font-size:26rpx; font-weight:700; }

/* Modal */
.modal-overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.7); display:none; align-items:flex-end; justify-content:center; z-index:100; }
.modal-visible { display:flex; }
.modal { background:#1a1a1a; border-radius:30rpx 30rpx 0 0; padding:32rpx 28rpx 60rpx; width:100%; }
.modal-title { font-size:30rpx; font-weight:800; color:#fff; display:block; margin-bottom:20rpx; }
.modal-input { background:#111; border:1rpx solid #2a2a2a; border-radius:14rpx; padding:20rpx; font-size:26rpx; color:#fff; width:100%; box-sizing:border-box; min-height:120rpx; margin-bottom:20rpx; }
.modal-actions { display:flex; gap:14rpx; }
.modal-btn-cancel { flex:1; background:transparent; border:1rpx solid #333; color:#666; border-radius:16rpx; padding:20rpx; font-size:26rpx; }
.modal-btn-confirm { flex:1; background:#7f1d1d; border:none; color:#f87171; border-radius:16rpx; padding:20rpx; font-size:26rpx; font-weight:700; }
