/* pages/tiers/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; }

.topbar { background:#0b0b0c; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:56rpx; height:56rpx; background:#1a1a22; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-arrow { font-size:32rpx; color:#f3f3f4; }
.topbar-title { flex:1; text-align:center; font-size:32rpx; font-weight:800; color:#f3f3f4; }

.scroll { flex:1; padding:28rpx 24rpx; }

.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a33; border-top-color:#e8342a; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

.section-label { font-size:22rpx; color:#5d5d65; font-weight:700; letter-spacing:2rpx; display:block; margin-bottom:20rpx; }

.tier-card {
  background:#13131a;
  border:1rpx solid #2a2a33;
  border-radius:20rpx;
  padding:32rpx 28rpx;
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:16rpx;
}

.tier-left { display:flex; flex-direction:column; gap:6rpx; }
.tier-name { font-size:36rpx; font-weight:800; }
.tier-sub { font-size:24rpx; color:#5d5d65; }
.tier-arrow { font-size:48rpx; font-weight:300; }

.pdf-wrap { padding:40rpx 0 80rpx; }

.btn-pdf {
  display:block;
  background:transparent;
  border:1rpx solid #2a2a33;
  color:#5d5d65;
  border-radius:100rpx;
  padding:26rpx 0;
  font-size:28rpx;
  font-weight:600;
  text-align:center;
  width:100%;
}
