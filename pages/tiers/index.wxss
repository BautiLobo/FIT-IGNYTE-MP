/* pages/tiers/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; overflow:hidden; }

/* ── TOPBAR ── */
.topbar { background:#0b0b0c; padding:80rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; display:flex; align-items:center; flex-shrink:0; }
.back-btn { width:60rpx; height:60rpx; background:#1a1a22; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-arrow { font-size:36rpx; color:#f3f3f4; font-weight:300; }
.topbar-title { flex:1; text-align:center; font-size:32rpx; font-weight:800; color:#f3f3f4; }

/* ── SCROLL ── */
.scroll { flex:1; padding:24rpx 24rpx; box-sizing:border-box; overflow-x:hidden; }

.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a33; border-top-color:#e8342a; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* ── HEADER ── */
.list-header { display:flex; flex-direction:column; gap:6rpx; margin-bottom:28rpx; padding:8rpx 4rpx; }
.list-title { font-size:36rpx; font-weight:800; color:#f3f3f4; display:block; }
.list-sub { font-size:24rpx; color:#a0a0aa; display:block; }

/* ── TIER CARDS ── */
.tier-wrap { margin-bottom:16rpx; }

.tier-card {
  background: #13131a;
  border: 1rpx solid #2a2a33;
  border-left: 4rpx solid;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  width: 100%;
}

.tier-left { display:flex; flex-direction:column; gap:6rpx; }
.tier-tag { font-size:20rpx; font-weight:700; letter-spacing:2rpx; display:block; }
.tier-name { font-size:38rpx; font-weight:800; color:#f3f3f4; display:block; }
.tier-sub { font-size:24rpx; color:#9f9fa8; display:block; }
.tier-arrow { font-size:48rpx; font-weight:300; }

/* ── HINT ── */
.hint-wrap { display:flex; align-items:center; gap:16rpx; padding:32rpx 4rpx; }
.hint-line { flex:1; height:1rpx; background:#9f9fa8; display:block; }
.hint { font-size:22rpx; color:#9f9fa8; white-space:nowrap; }

/* ── BOTTOM BAR ── */
.bottom-bar { padding:8rpx 0 40rpx; }
button { margin:0 !important; padding:0 !important; background:transparent; border:none; }
.btn-pdf { background:#1a1a22 !important; border-radius:100rpx !important; height:80rpx; line-height:80rpx; font-size:26rpx !important; color:#a0a0aa !important; width:100% !important; text-align:center; box-sizing:border-box; }
