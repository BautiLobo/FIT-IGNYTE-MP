<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">Choose your plan</text>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:else>

      <text class="section-label">What's your goal?</text>

      <view wx:for="{{tiers}}" wx:key="name" class="tier-card" bindtap="selectTier" data-tier="{{item.name}}">
        <view class="tier-left">
          <text class="tier-name" style="color:{{item.color}};">{{item.name}}</text>
          <text class="tier-sub">{{item.planCount}} plans available</text>
        </view>
        <text class="tier-arrow" style="color:{{item.color}};">›</text>
      </view>

      <!-- PDF Button -->
      <view class="pdf-wrap">
        <button class="btn-pdf" bindtap="openBrochure">View full menu PDF</button>
      </view>

    </block>

  </scroll-view>

</view>
