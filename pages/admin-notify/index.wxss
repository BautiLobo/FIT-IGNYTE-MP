/* pages/admin-notify/index.wxss */
.container { display:flex; flex-direction:column; height:100vh; background:#0d0d0d; }
.topbar { background:#111; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:60rpx; }
.back-arrow { font-size:48rpx; color:#E8342A; font-weight:300; }
.topbar-center { flex:1; text-align:center; }
.topbar-title { font-size:32rpx; font-weight:800; color:#fff; display:block; }
.topbar-right { width:60rpx; }
.scroll { flex:1; padding:24rpx 28rpx; }
.section-label { font-size:20rpx; color:#555; text-transform:uppercase; letter-spacing:2rpx; font-weight:700; display:block; margin-bottom:12rpx; }

/* Recipient Tabs */
.recipient-tabs { display:flex; gap:12rpx; margin-bottom:24rpx; }
.recipient-tab { flex:1; background:#111; border:1rpx solid #1e1e1e; border-radius:16rpx; padding:18rpx; text-align:center; font-size:24rpx; color:#555; font-weight:600; display:flex; align-items:center; justify-content:center; gap:6rpx; }
.recipient-tab-active { border-color:#E8342A; color:#E8342A; background:#1a0808; }
.recipient-count { font-size:20rpx; color:#666; }

/* Client List */
.client-list { background:#111; border:1rpx solid #1e1e1e; border-radius:20rpx; overflow:hidden; margin-bottom:24rpx; max-height:360rpx; overflow-y:auto; }
.client-row { display:flex; align-items:center; padding:18rpx 22rpx; border-bottom:1rpx solid #1a1a1a; }
.client-row:last-child { border-bottom:none; }
.client-row-selected { background:#1a0808; }
.client-info { flex:1; }
.client-name { font-size:26rpx; color:#fff; font-weight:600; display:block; }
.client-plan { font-size:20rpx; color:#555; display:block; margin-top:2rpx; }
.client-check { color:#E8342A; font-size:28rpx; font-weight:800; }

/* Fields */
.field-input { background:#111; border:1rpx solid #1e1e1e; border-radius:14rpx; padding:22rpx 24rpx; font-size:28rpx; color:#fff; width:100%; box-sizing:border-box; margin-bottom:24rpx; }
.field-textarea { background:#111; border:1rpx solid #1e1e1e; border-radius:14rpx; padding:22rpx 24rpx; font-size:28rpx; color:#fff; width:100%; box-sizing:border-box; min-height:160rpx; margin-bottom:24rpx; }

/* Send Button */
.btn-send { background:#E8342A; border:none; color:#fff; border-radius:20rpx; padding:26rpx; font-size:30rpx; font-weight:800; width:100%; margin-bottom:32rpx; }
.btn-send-disabled { opacity:0.4; }

/* Recent */
.recent-row { background:#111; border:1rpx solid #1e1e1e; border-radius:16rpx; padding:18rpx 22rpx; display:flex; gap:14rpx; margin-bottom:12rpx; }
.recent-info { flex:1; }
.recent-title { font-size:24rpx; color:#fff; font-weight:700; display:block; }
.recent-msg { font-size:22rpx; color:#666; display:block; margin-top:4rpx; }
.recent-meta { display:flex; flex-direction:column; align-items:flex-end; gap:6rpx; flex-shrink:0; }
.recent-to { font-size:20rpx; color:#E8342A; font-weight:700; }
.recent-date { font-size:18rpx; color:#444; }
