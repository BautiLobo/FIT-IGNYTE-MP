<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">‹</text>
    </view>
    <view class="topbar-center">
      <text class="topbar-title">Send notification</text>
    </view>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <text class="section-label">SEND TO</text>
    <view class="recipient-tabs">
      <view
        class="recipient-tab recipient-tab-all {{recipientType === 'all' ? 'recipient-tab-all-active' : ''}}"
        bindtap="setRecipientType"
        data-type="all"
      >
        <text>Everyone ({{clientCount}})</text>
      </view>
      <view
        class="recipient-tab recipient-tab-one {{recipientType === 'one' ? 'recipient-tab-one-active' : ''}}"
        bindtap="setRecipientType"
        data-type="one"
      >
        <text>Select clients{{selectedClientIds.length > 0 ? ' (' + selectedClientIds.length + ')' : ''}}</text>
      </view>
    </view>

    <view wx:if="{{recipientType === 'one'}}" class="client-list">
      <view
        wx:for="{{clients}}"
        wx:key="id"
        class="client-row {{item.selected ? 'client-row-selected' : ''}}"
        bindtap="toggleClient"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
      >
        <view class="client-info">
          <text class="client-name">{{item.name}}</text>
          <text class="client-plan">{{item.plan_name}}</text>
        </view>
        <view class="client-checkbox {{item.selected ? 'client-checkbox-on' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
      </view>
    </view>

    <text class="section-label">TITLE</text>
    <input
      class="field-input"
      placeholder="e.g. Menu update, Delivery change..."
      value="{{title}}"
      bindinput="onTitleInput"
    />

    <text class="section-label">MESSAGE</text>
    <textarea
      class="field-textarea"
      placeholder="Write your message here..."
      value="{{message}}"
      bindinput="onMessageInput"
      auto-height
    />

    <view class="btn-wrap">
      <view class="btn-send {{canSend ? '' : 'btn-send-disabled'}}" bindtap="send">
        <text>{{sending ? 'Sending...' : 'Send notification'}}</text>
      </view>
    </view>

    <text class="section-label" wx:if="{{recent.length > 0}}">RECENTLY SENT</text>
    <view wx:for="{{recent}}" wx:key="id" class="recent-row">
<view class="recent-info">
        <text class="recent-title">{{item.title}}</text>
        <text class="recent-msg">{{item.message}}</text>
      </view>
      <view class="recent-meta">
        <text class="recent-to">{{item.client_id ? item.client_name : 'EVERYONE'}}</text>
        <text class="recent-date">{{item.created_at_formatted}}</text>
      </view>
    </view>

  </scroll-view>

</view>
