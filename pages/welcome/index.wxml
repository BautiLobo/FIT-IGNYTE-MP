<view class="container">

  <view class="hero-bg">
    <image class="hero-logo" src="/images/mark.png" mode="aspectFit" />
  </view>

  <view class="content">

    <view class="text-block">
      <text class="hero-title">{{lbl_title}}</text>
      <text class="hero-sub"></text>
    </view>

    <view class="btn-wrap">
      <button class="btn-primary" bindtap="goToHome">{{lbl_go_home}}</button>
    </view>

  </view>

</view>
