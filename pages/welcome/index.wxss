/* pages/welcome/index.wxss */
.container { display:flex; flex-direction:column; height:100vh; background:#0d0d0d; }
.topbar { background:#111; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; }
.brand { font-size:32rpx; font-weight:800; letter-spacing:4rpx; color:#fff; }
.brand-red { color:#E8342A; }
.content { flex:1; display:flex; flex-direction:column; padding:40rpx 28rpx; gap:24rpx; }
.hero { display:flex; flex-direction:column; align-items:center; text-align:center; padding:20rpx 0; gap:16rpx; }
.hero-icon { width:130rpx; height:130rpx; background:#052e16; border:4rpx solid #166534; border-radius:50%; font-size:56rpx; display:flex; align-items:center; justify-content:center; }
.hero-title { font-size:40rpx; font-weight:800; color:#fff; }
.hero-sub { font-size:24rpx; color:#666; }
.card { background:#111; border:1rpx solid #1e1e1e; border-radius:20rpx; padding:24rpx; }
.card-label { font-size:20rpx; color:#555; text-transform:uppercase; letter-spacing:2rpx; font-weight:700; display:block; margin-bottom:16rpx; }
.row { display:flex; justify-content:space-between; padding:10rpx 0; }
.row-border { border-bottom:1rpx solid #161616; }
.row-key { font-size:24rpx; color:#666; }
.row-val { font-size:24rpx; color:#fff; font-weight:700; }
.first-meals { font-size:22rpx; color:#bbb; display:block; padding-top:12rpx; }
.btn-primary { background:#E8342A; border:none; color:#fff; border-radius:20rpx; padding:26rpx; font-size:32rpx; font-weight:800; width:100%; margin-top:auto; }
