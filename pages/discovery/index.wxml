<view class="container" wx:if="{{!checking}}">

  <!-- Logo + tagline -->
  <view class="top-section">
    <view class="logo-glow"></view>
    <image class="logo" src="/images/logo.png" mode="aspectFit" />
    <view class="tagline-wrap">
      <text class="tagline">{{lbl_tagline1}}</text>
      <text class="tagline">{{lbl_tagline2}}</text>
    </view>
    <text class="sub-tagline">{{lbl_sub_tagline}}</text>
  </view>

  <!-- Promo banner -->
  <view class="discount-wrap">
    <image class="discount-banner-img" src="/images/promo-banner.png" mode="aspectFill" />
  </view>

  <!-- Buttons -->
  <view class="btn-wrap">
    <button class="btn-plans" bindtap="openBrochure">{{lbl_see_plans}}</button>
    <button class="btn-start" bindtap="goToTiers">{{lbl_get_started}}</button>
  </view>

</view>
