<view class="container" wx:if="{{!checking}}">

  <!-- Logo + tagline -->
  <view class="top-section">
    <view class="logo-glow"></view>
    <image class="logo" src="/images/logo.png" mode="aspectFit" />
    <view class="tagline-wrap">
      <text class="tagline">Fitness meals,</text>
      <text class="tagline">ready every morning</text>
    </view>
    <text class="sub-tagline">WEEKLY PLANS · MON-FRI</text>
  </view>

  <!-- Promo banner -->
  <view class="discount-wrap">
    <image class="discount-banner-img" src="/images/promo-banner.png" mode="aspectFill" />
  </view>

  <!-- Buttons -->
  <view class="btn-wrap">
    <button class="btn-plans" bindtap="openBrochure">☰  See our plans</button>
    <button class="btn-start" bindtap="goToTiers">Get started  →</button>
  </view>

</view>
