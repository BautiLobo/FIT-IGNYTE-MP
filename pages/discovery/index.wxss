/* pages/discovery/index.wxss */

.container {
  height: 100vh;
  background: #0b0b0c;
  display: flex;
  flex-direction: column;
}

/* ── LOGO + TAGLINE ── */
.top-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx 28rpx;
  gap: 20rpx;
  background: radial-gradient(ellipse at 50% 30%, #3a0a0a 0%, #0b0b0c 65%);
}

.logo-glow {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(232,52,42,0.35) 0%, rgba(232,52,42,0) 70%);
  filter: blur(10rpx);
  z-index: 0;
}

.logo {
  width: 400rpx;
  height: 120rpx;
  position: relative;
  z-index: 1;
}

.tagline-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.tagline {
  font-size: 56rpx;
  font-weight: 800;
  font-style: italic;
  color: #f3f3f4;
  line-height: 1.2;
  display: block;
  text-align: center;
}

.sub-tagline {
  font-size: 20rpx;
  color: #5d5d65;
  letter-spacing: 5rpx;
  font-weight: 600;
  text-align: center;
  margin-top: 6rpx;
  position: relative;
  z-index: 1;
}

/* ── DISCOUNT BANNER ── */
.discount-wrap {
  padding: 0 28rpx;
  margin-top: 8rpx;
  box-sizing: border-box;
  width: 100%;
}

.discount-banner {
  background: repeating-linear-gradient(135deg, #16161c 0 18rpx, #1c1c22 18rpx 36rpx);
  border: 1rpx solid #2a2a33;
  border-radius: 20rpx;
  height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-sizing: border-box;
  width: 100%;
}

.discount-label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  text-align: center;
}

.discount-main {
  font-size: 88rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  display: block;
  letter-spacing: -1rpx;
  text-align: center;
}

.discount-sub {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.8);
  display: block;
  text-align: center;
}

/* ── BUTTONS ── */
.btn-wrap {
  padding: 24rpx 28rpx 64rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: auto;
  margin-bottom: 40rpx;
  box-sizing: border-box;
  width: 100%;
}

button { margin: 0 !important; padding: 0 !important; background: transparent; border: none; }

.btn-start {
  background: #e8342a !important;
  border-radius: 100rpx !important;
  height: 100rpx;
  line-height: 100rpx;
  color: #fff !important;
  font-size: 34rpx !important;
  font-weight: 800 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}

.btn-plans {
  background: #1a1a22 !important;
  border-radius: 100rpx !important;
  height: 92rpx;
  line-height: 92rpx;
  color: #f3f3f4 !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}
