/* pages/discovery/index.wxss */

.container {
  height: 100vh;
  background: #0b0b0c;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ── LOGO + TAGLINE ── */
.top-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx 28rpx;
  gap: 20rpx;
}

.logo-glow {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle, rgba(232,52,42,0.45) 0%, rgba(232,52,42,0.15) 45%, rgba(232,52,42,0) 100%);
  filter: blur(40rpx);
  z-index: 0;
}

.logo {
  width: 400rpx;
  height: 220rpx;
  position: relative;
  z-index: 1;
}

.tagline-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.tagline {
  font-size: 56rpx;
  font-weight: 800;
  font-style: italic;
  color: #f3f3f4;
  line-height: 1.2;
  display: block;
  text-align: center;
}

.sub-tagline {
  font-size: 28rpx;
  color: #5d5d65;
  letter-spacing: 5rpx;
  font-weight: 600;
  text-align: center;
  margin-top: 6rpx;
  position: relative;
  z-index: 1;
}

/* ── PROMO BANNER ── */
.discount-wrap {
  padding: 0 28rpx;
  margin-top: 8rpx;
  box-sizing: border-box;
  width: 100%;
}

.discount-banner-img {
  width: 100%;
  height: 220rpx;
  border-radius: 20rpx;
  display: block;
}

/* ── BUTTONS ── */
.btn-wrap {
  padding: 48rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-sizing: border-box;
  width: 100%;
}

button { margin: 0 !important; padding: 0 !important; background: transparent; border: none; }

.btn-start {
  background: #e8342a !important;
  border-radius: 24rpx !important;
  height: 100rpx;
  line-height: 100rpx;
  color: #fff !important;
  font-size: 34rpx !important;
  font-weight: 800 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}

.btn-plans {
  background: rgba(167,139,250,0.12) !important;
  border: 2rpx solid #f77a05 !important;
  border-radius: 24rpx !important;
  height: 92rpx;
  line-height: 92rpx;
  color: #f77a05 !important;
  font-size: 30rpx !important;
  font-weight: 800 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}
