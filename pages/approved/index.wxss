/* pages/approved/index.wxss */
.container { display:flex; flex-direction:column; height:100vh; background:#0d0d0d; }
.topbar { background:#111; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; }
.brand { font-size:32rpx; font-weight:800; letter-spacing:4rpx; color:#fff; }
.brand-red { color:#E8342A; }
.scroll { flex:1; padding:24rpx 28rpx; }
.hero { text-align:center; padding:40rpx 0 24rpx; display:flex; flex-direction:column; align-items:center; gap:16rpx; }
.hero-icon { width:130rpx; height:130rpx; background:#052e16; border:4rpx solid #166534; border-radius:50%; font-size:56rpx; display:flex; align-items:center; justify-content:center; margin-bottom:8rpx; }
.hero-title { font-size:36rpx; font-weight:800; color:#fff; }
.hero-sub { font-size:24rpx; color:#666; }
.card { background:#111; border:1rpx solid #1e1e1e; border-radius:20rpx; padding:24rpx; margin-bottom:18rpx; }
.card-label { font-size:20rpx; color:#555; text-transform:uppercase; letter-spacing:2rpx; font-weight:700; display:block; margin-bottom:16rpx; }
.row { display:flex; justify-content:space-between; align-items:center; padding:10rpx 0; }
.row-border { border-bottom:1rpx solid #161616; }
.row-key { font-size:24rpx; color:#666; }
.row-val { font-size:24rpx; color:#fff; font-weight:700; }
.first-meals { font-size:22rpx; color:#bbb; display:block; padding-top:10rpx; }
.next-list { font-size:24rpx; color:#bbb; line-height:2; display:block; }
.btn-primary { background:#E8342A; border:none; color:#fff; border-radius:20rpx; padding:26rpx; font-size:32rpx; font-weight:800; width:100%; margin-bottom:14rpx; }
.btn-secondary { background:#111; border:1rpx solid #1e1e1e; color:#666; border-radius:20rpx; padding:22rpx; font-size:26rpx; width:100%; margin-bottom:60rpx; }
