/* pages/approved/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0b0b0c;
  overflow: hidden;
}

.topbar {
  padding: 80rpx 28rpx 24rpx;
  border-bottom: 1rpx solid #1a1a22;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.topbar-logo { width: 120rpx; height: 120rpx; }

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  box-sizing: border-box;
  width: 100%;
  gap: 36rpx;
}

/* ── CIRCLE ── */
.circle-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
}

.hero-circle {
  width: 220rpx;
  height: 220rpx;
  background: #052e16;
  border: 4rpx solid #16a34a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-check { font-size: 108rpx; color: #4ade80; font-weight: 300; line-height: 1; }

/* ── TITLE ── */
.title-wrap { width: 100%; text-align: center; }
.hero-title { font-size: 52rpx; font-weight: 900; font-style: italic; color: #f3f3f4; display: block; line-height: 1.3; }

/* ── SUB ── */
.sub-wrap { width: 100%; text-align: center; }
.hero-sub { font-size: 28rpx; color: #6b6b75; display: block; }

/* ── DELIVERY CARD ── */
.delivery-card-wrap { width: 100%; box-sizing: border-box; }

.delivery-card {
  background: #13131a;
  border: 1rpx solid #1a1a22;
  border-radius: 20rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.delivery-row { display: flex; align-items: center; gap: 16rpx; }

.delivery-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  background: #2a0808;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.delivery-icon { font-size: 30rpx; }

.delivery-body { flex: 1; display: flex; flex-direction: column; gap: 4rpx; overflow: hidden; }
.delivery-day { font-size: 32rpx; font-weight: 800; color: #f3f3f4; display: block; }
.delivery-meals { font-size: 24rpx; color: #5d5d65; display: block; line-height: 1.4; }

.delivery-time-badge { background: #e8342a; border-radius: 100rpx; padding: 10rpx 20rpx; flex-shrink: 0; }
.delivery-time-text { font-size: 24rpx; font-weight: 700; color: #fff; }

/* ── BUTTONS ── */
.btn-wrap { width: 100%; box-sizing: border-box; }

.btn-wrap {
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
}

button { margin: 0 !important; padding: 0 !important; background: transparent; border: none; }

.btn-primary {
  background: #e8342a !important;
  border-radius: 24rpx !important;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx !important;
  font-weight: 800 !important;
  color: #fff !important;
  width: 100% !important;
  text-align: center;
  box-sizing: border-box;
  display: block;
  margin-bottom: 20rpx !important;
}

.btn-secondary {
  background: #1a1a22 !important;
  border-radius: 24rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  color: #6b6b75 !important;
  width: 100% !important;
  text-align: center;
  box-sizing: border-box;
  display: block;
}
