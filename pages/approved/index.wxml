<view class="container">

  <view class="topbar">
    <image class="topbar-logo" src="/images/mark.png" mode="aspectFit" />
  </view>

  <view class="content">

    <view class="circle-wrap">
      <view class="hero-circle">
        <text class="hero-check">✓</text>
      </view>
    </view>

    <view class="title-wrap">
      <text class="hero-title">You're all set, {{firstName}}!</text>
    </view>

    <view class="sub-wrap">
      <text class="hero-sub">Welcome to FIT IGNYTE</text>
    </view>


    <view class="btn-wrap">
      <button class="btn-primary" bindtap="goToPayment">Complete payment →</button>
    </view>

    <view class="btn-wrap">
      <button class="btn-secondary" bindtap="contactUs">💬  Contact FIT IGNYTE</button>
    </view>

  </view>

</view>
