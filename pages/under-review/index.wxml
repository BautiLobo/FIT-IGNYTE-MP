<view class="container">

  <!-- Logo topbar -->
  <view class="topbar">
    <image class="topbar-logo" src="/images/mark.png" mode="aspectFit" />
  </view>

  <scroll-view class="scroll" scroll-y>

    <!-- Hero icon -->
    <view class="hero">
      <view class="hero-circle">
        <text class="hero-clock">◷</text>
      </view>
      <text class="hero-title">{{lbl_title}}</text>
      <text class="hero-sub">{{lbl_body}}</text>
    </view>

    <!-- Order summary -->
    <view class="card">
      <view class="summary-row summary-border">
        <text class="summary-key">{{lbl_plan}}</text>
        <text class="summary-val">{{order.plan_name}} · ¥{{order.plan_price}}/wk</text>
      </view>
      <view class="summary-row">
        <text class="summary-key">{{lbl_district}}</text>
        <text class="summary-val">{{order.district}}</text>
      </view>
    </view>

    <!-- Status steps -->
    <view class="card">
      <view class="step-row">
        <view class="step-dot step-done-dot">
          <text class="step-check">✓</text>
        </view>
        <text class="step-label step-done">{{lbl_step1}}</text>
      </view>
      <view class="step-divider"></view>
      <view class="step-row">
        <view class="step-dot step-active-dot">
          <view class="step-inner-dot"></view>
        </view>
        <text class="step-label step-active">{{lbl_step2}}</text>
      </view>
      <view class="step-divider"></view>
      <view class="step-row">
        <view class="step-dot step-idle-dot"></view>
        <text class="step-label step-idle">{{lbl_step3}}</text>
      </view>
    </view>

  </scroll-view>

  <!-- Fixed bottom -->
  <view class="bottom-bar">
    <button class="btn-contact" open-type="contact">{{lbl_contact}}</button>
    <text class="hint">{{lbl_eta}}</text>
  </view>

</view>
