<view class="container">

  <!-- Logo topbar -->
  <view class="topbar">
    <image class="topbar-logo" src="/images/mark.png" mode="aspectFit" />
  </view>

  <scroll-view class="scroll" scroll-y>

    <!-- Hero icon -->
    <view class="hero">
      <view class="hero-circle">
        <text class="hero-clock">◷</text>
      </view>
      <text class="hero-title">Reviewing your order</text>
      <text class="hero-sub">We're checking delivery coverage in your area. We'll notify you on WeChat shortly.</text>
    </view>

    <!-- Order summary -->
    <view class="card">
      <view class="summary-row summary-border">
        <text class="summary-key">Plan</text>
        <text class="summary-val">{{order.plan_name}} · ¥{{order.plan_price}}/wk</text>
      </view>
      <view class="summary-row">
        <text class="summary-key">District</text>
        <text class="summary-val">{{order.district}}</text>
      </view>
    </view>

    <!-- Status steps -->
    <view class="card">
      <view class="step-row">
        <view class="step-dot step-done-dot">
          <text class="step-check">✓</text>
        </view>
        <text class="step-label step-done">Order received</text>
      </view>
      <view class="step-divider"></view>
      <view class="step-row">
        <view class="step-dot step-active-dot">
          <view class="step-inner-dot"></view>
        </view>
        <text class="step-label step-active">Checking area</text>
      </view>
      <view class="step-divider"></view>
      <view class="step-row">
        <view class="step-dot step-idle-dot"></view>
        <text class="step-label step-idle">Payment — pending</text>
      </view>
    </view>

  </scroll-view>

  <!-- Fixed bottom -->
  <view class="bottom-bar">
    <button class="btn-contact" bindtap="contactUs">Contact us while you wait</button>
    <text class="hint">Usually reviewed in under 1 hour</text>
  </view>

</view>
