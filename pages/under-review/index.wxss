/* pages/under-review/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0b0b0c;
  overflow: hidden;
}

/* ── TOPBAR ── */
.topbar {
  padding: 80rpx 28rpx 24rpx;
  border-bottom: 1rpx solid #1a1a22;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.topbar-logo { width: 80rpx; height: 80rpx; }

/* ── SCROLL ── */
.scroll { flex: 1; padding: 0 28rpx; box-sizing: border-box; overflow-x: hidden; }

/* ── HERO ── */
.hero {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 56rpx 16rpx 48rpx;
}

.hero-circle {
  width: 180rpx;
  height: 180rpx;
  background: #1a1500;
  border: 3rpx solid #b45309;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.hero-clock {
  font-size: 80rpx;
  color: #d97706;
  line-height: 1;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #f3f3f4;
  display: block;
}

.hero-sub {
  font-size: 28rpx;
  color: #6b6b75;
  line-height: 1.7;
  display: block;
  padding: 0 8rpx;
}

/* ── CARD ── */
.card {
  background: #13131a;
  border: 1rpx solid #1a1a22;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* ── SUMMARY ── */
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}
.summary-border { border-bottom: 1rpx solid #1a1a22; }
.summary-key { font-size: 28rpx; color: #5d5d65; }
.summary-val { font-size: 28rpx; color: #f3f3f4; font-weight: 600; }

/* ── STEPS ── */
.step-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 8rpx 0;
}

.step-divider {
  width: 2rpx;
  height: 32rpx;
  background: #2a2a33;
  margin-left: 19rpx;
}

.step-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-done-dot { background: #16a34a; }
.step-check { font-size: 24rpx; color: #fff; font-weight: 800; }

.step-active-dot { background: transparent; border: 3rpx solid #d97706; }
.step-inner-dot { width: 18rpx; height: 18rpx; border-radius: 50%; background: #d97706; }

.step-idle-dot { background: transparent; border: 2rpx solid #2a2a33; }

.step-label { font-size: 32rpx; font-weight: 600; }
.step-done { color: #4ade80; }
.step-active { color: #d97706; }
.step-idle { color: #3a3a45; }

/* ── BOTTOM BAR ── */
.bottom-bar {
  padding: 20rpx 28rpx 56rpx;
  border-top: 1rpx solid #1a1a22;
  background: #0b0b0c;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

button { margin:0 !important; padding:0 !important; background:transparent; border:none; }

.btn-contact {
  background: transparent !important;
  border: 2rpx solid #e8342a !important;
  border-radius: 24rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  color: #e8342a !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}

.hint {
  font-size: 22rpx;
  color: #3a3a45;
  text-align: center;
  display: block;
}
