/* pages/meal-select/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; }

/* Topbar */
.topbar { background:#0b0b0c; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; display:flex; align-items:center; flex-shrink:0; }
.back-btn { width:56rpx; height:56rpx; background:#1a1a22; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-arrow { font-size:32rpx; color:#f3f3f4; }
.topbar-title { flex:1; text-align:center; font-size:32rpx; font-weight:800; color:#f3f3f4; }

/* Day Tabs */
.day-tabs { white-space:nowrap; padding:16rpx 20rpx; background:#0b0b0c; border-bottom:1rpx solid #1a1a22; flex-shrink:0; }
.day-tab { display:inline-flex; flex-direction:column; align-items:center; gap:6rpx; background:#13131a; border:1rpx solid #2a2a33; color:#5d5d65; padding:16rpx 32rpx; border-radius:16rpx; margin-right:10rpx; min-width:110rpx; }
.day-tab-active { background:#1a0808; border-color:#e8342a; color:#e8342a; }
.day-tab-short { font-size:30rpx; font-weight:700; }
.day-tab-sub { font-size:18rpx; color:#5d5d65; }
.day-tab-sub-active { color:#e8342a; }

/* Scroll */
.scroll { flex:1; padding:16rpx 24rpx; }

/* Loading */
.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a33; border-top-color:#e8342a; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* Plan Badge */
.plan-badge { background:#1a0a2a; border:1rpx solid #4a3a6a; border-radius:14rpx; padding:12rpx 20rpx; display:flex; justify-content:space-between; align-items:center; margin-bottom:14rpx; }
.plan-badge-text { font-size:24rpx; color:#A78BFA; font-weight:700; }
.plan-badge-change { font-size:20rpx; color:#5d5d65; text-decoration:underline; }

/* Confirmed */
.confirmed-meal { background:#0a1a0a; border:1rpx solid #166534; border-radius:18rpx; padding:22rpx 24rpx; display:flex; align-items:center; gap:16rpx; margin-bottom:14rpx; }
.confirmed-photo { width:70rpx; height:70rpx; border-radius:12rpx; flex-shrink:0; }
.confirmed-thumb-placeholder { width:70rpx; height:70rpx; border-radius:12rpx; background:#1a1a22; display:flex; align-items:center; justify-content:center; font-size:28rpx; flex-shrink:0; }
.confirmed-info { flex:1; }
.confirmed-label { font-size:24rpx; color:#4ade80; font-weight:700; display:block; }
.confirmed-name { font-size:28rpx; color:#fff; font-weight:600; display:block; margin-top:6rpx; }
.confirmed-time-badge { background:#052e16; color:#4ade80; font-size:24rpx; font-weight:800; padding:8rpx 18rpx; border-radius:12rpx; flex-shrink:0; }
.confirmed-edit { font-size:26rpx; color:#e8342a; background:#1a0808; padding:8rpx 16rpx; border-radius:10rpx; font-weight:700; }

/* Photo Preview */
.photo-preview { background:#13131a; border:1rpx solid #2a2a33; border-radius:20rpx; height:200rpx; display:flex; align-items:center; justify-content:center; margin-bottom:16rpx; overflow:hidden; position:relative; }
.photo-preview-active { height:340rpx; border-color:#e8342a; }
.photo-large { width:100%; height:100%; }
.photo-empty-inner { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8rpx; }
.photo-overlay { position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent, rgba(0,0,0,0.85)); padding:16rpx 20rpx; display:flex; align-items:center; justify-content:space-between; }
.photo-meal-name { font-size:26rpx; font-weight:700; color:#fff; flex:1; }
.photo-check { background:#e8342a; color:#fff; font-size:20rpx; width:40rpx; height:40rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

/* Section label */
.section-label { font-size:20rpx; color:#5d5d65; font-weight:700; letter-spacing:2rpx; display:block; margin-bottom:10rpx; }

/* Meal List */
.meal-list { background:#13131a; border:1rpx solid #2a2a33; border-radius:20rpx; overflow:hidden; margin-bottom:8rpx; }
.meal-row { display:flex; align-items:center; gap:20rpx; padding:24rpx 24rpx; border-bottom:1rpx solid #1a1a22; }
.meal-row:last-child { border-bottom:none; }
.meal-row-selected { background:#1a0808; border-left:4rpx solid #e8342a; }

.meal-thumb-wrap { width:110rpx; height:110rpx; border-radius:16rpx; overflow:hidden; flex-shrink:0; }
.meal-thumb { width:100%; height:100%; }
.meal-thumb-placeholder { width:110rpx; height:110rpx; background:#2a2a33; border-radius:16rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.meal-thumb-label { font-size:16rpx; color:#5d5d65; font-weight:700; letter-spacing:1rpx; text-align:center; }

.meal-info { flex:1; }
.meal-name { font-size:32rpx; color:#ccc; display:block; font-weight:700; }
.meal-name-active { color:#e8342a; font-weight:800; }
.meal-desc { font-size:26rpx; color:#5d5d65; display:block; margin-top:6rpx; }
.meal-desc-active { color:#e8342a; }
.meal-check { width:30rpx; height:30rpx; border:2rpx solid #2a2a33; border-radius:50%; flex-shrink:0; }
.meal-check-on { background:#e8342a; border-color:#e8342a; display:flex; align-items:center; justify-content:center; }
.scroll-hint { font-size:20rpx; color:#3a3a3a; text-align:center; display:block; margin-bottom:16rpx; }

/* Time Picker */
.time-picker { background:#13131a; border:1rpx solid #e8342a; border-radius:20rpx; padding:18rpx 22rpx; margin-bottom:14rpx; }
.time-picker-label { font-size:20rpx; color:#e8342a; font-weight:700; letter-spacing:2rpx; display:block; margin-bottom:14rpx; }
.time-picker-inner { display:flex; align-items:center; gap:16rpx; }
.time-col { display:flex; flex-direction:column; align-items:center; gap:6rpx; }
.time-arrow { font-size:20rpx; color:#5d5d65; padding:4rpx 12rpx; }
.time-box { background:#e8342a; color:#fff; font-size:36rpx; font-weight:800; width:70rpx; height:60rpx; border-radius:12rpx; display:flex; align-items:center; justify-content:center; }
.time-colon { font-size:36rpx; font-weight:800; color:#5d5d65; }
.time-display { flex:1; margin-left:16rpx; display:flex; flex-direction:column; }
.time-display-value { font-size:48rpx; font-weight:800; color:#fff; line-height:1; }
.time-display-ampm { font-size:24rpx; color:#5d5d65; margin-top:4rpx; }

/* Notes */
.notes-wrap { background:#13131a; border:1rpx solid #2a2a33; border-radius:18rpx; padding:16rpx 22rpx; margin-bottom:14rpx; }
.notes-label { font-size:22rpx; color:#5d5d65; font-weight:700; display:block; margin-bottom:8rpx; }
.notes-input { background:#1a1a22; border:1rpx solid #2a2a33; border-radius:12rpx; padding:14rpx 18rpx; font-size:26rpx; color:#ccc; width:100%; min-height:70rpx; }

/* Buttons */
.btn-confirm { display:block; background:#e8342a; border:none; color:#fff; border-radius:100rpx; padding:26rpx 0; font-size:30rpx; font-weight:800; text-align:center; width:100%; margin-bottom:14rpx; }

/* Snack */
.snack-wrap { margin-bottom:16rpx; }
.snack-inner { background:#13131a; border:1rpx solid #2a2a33; border-radius:18rpx; padding:26rpx 28rpx; display:flex; align-items:center; justify-content:space-between; }
.snack-inner-added { background:#052e16; border-color:#166534; }
.snack-name { font-size:30rpx; color:#ccc; font-weight:600; }
.snack-badge { background:#2a2a33; color:#5d5d65; font-size:20rpx; padding:6rpx 18rpx; border-radius:24rpx; }
.snack-badge-added { background:#0a3a1a; color:#4ade80; }

/* Bottom */
.bottom-actions { padding-bottom:20rpx; }
.btn-skip { display:block; background:transparent; border:1rpx solid #2a2a33; color:#5d5d65; border-radius:100rpx; padding:22rpx 0; font-size:26rpx; text-align:center; width:100%; margin-bottom:12rpx; }
.progress-hint { font-size:22rpx; color:#5d5d65; text-align:center; display:block; margin-bottom:12rpx; }
.btn-next { display:block; background:#e8342a; border:none; color:#fff; border-radius:100rpx; padding:28rpx 0; font-size:32rpx; font-weight:800; text-align:center; width:100%; }
.btn-next-disabled { opacity:0.4; }

/* Contact */
.contact-wrap { padding:8rpx 0 60rpx; }
.btn-contact { display:block; background:#13131a; border:1rpx solid #2a2a33; color:#5d5d65; border-radius:100rpx; padding:22rpx 0; font-size:26rpx; text-align:center; width:100%; }

/* Native time picker */
.time-picker-display {
  background: #1a1a22;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-picker-value {
  font-size: 52rpx;
  font-weight: 800;
  color: #f3f3f4;
}

.time-picker-tap {
  font-size: 22rpx;
  color: #5d5d65;
}

.meal-check-num { font-size:18rpx; color:#fff; font-weight:800; }

/* Photo preview */
.photo-preview-wrap {
  border-radius:20rpx;
  overflow:hidden;
  height:280rpx;
  margin-bottom:16rpx;
  position:relative;
}

.photo-preview-img {
  width:100%;
  height:100%;
}

.photo-preview-overlay {
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  background:linear-gradient(transparent, rgba(0,0,0,0.85));
  padding:20rpx 24rpx;
}

.photo-preview-name {
  font-size:28rpx;
  font-weight:800;
  color:#fff;
  display:block;
}
