<view class="container">

  <!-- Top Bar -->
  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">{{lbl_title}}</text>
    <view style="width:60rpx;"></view>
  </view>

  <!-- Day Tabs -->
  <view class="day-tabs">
    <view
      wx:for="{{days}}"
      wx:key="key"
      class="day-tab {{currentDay === item.key ? 'day-tab-active' : ''}}"
      bindtap="switchDay"
      data-day="{{item.key}}"
    >
      <text class="day-tab-short">{{item.short}}</text>
      <text class="day-tab-check" wx:if="{{item.done}}">✓</text>
    </view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:else>

      <!-- Plan Badge -->
      <view class="plan-badge" wx:if="{{!fromHome}}">
        <text class="plan-badge-text">{{selectedPlan.displayName}} — {{selectedPlan.meals}} {{lbl_meals_day}}</text>
        <text class="plan-badge-change" bindtap="goBack">{{lbl_change_plan}}</text>
      </view>


      <!-- Photo preview — shows last selected meal photo -->
      <view wx:if="{{selectedMealIds.length > 0 && lastSelectedPhoto}}" class="photo-preview-wrap">
        <image class="photo-preview-img" src="{{lastSelectedPhoto}}" mode="aspectFill" />
        <view class="photo-preview-overlay">
          <text class="photo-preview-name">{{lastSelectedName}}</text>
        </view>
      </view>

      <!-- Meal List -->
      <view class="meal-list">
        <view
          wx:for="{{menuMeals}}"
          wx:key="id"
          class="meal-row {{item.qty > 0 ? 'meal-row-selected' : ''}}"
        >
          <view class="meal-row-top">
            <view class="meal-thumb-wrap">
              <image wx:if="{{item.photo_url}}" class="meal-thumb" src="{{item.photo_url}}" mode="aspectFill" />
              <view wx:else class="meal-thumb-placeholder">
                <text class="meal-thumb-label">{{item.displayName.substring(0,4).toUpperCase()}}</text>
              </view>
            </view>
            <view class="meal-info">
              <text class="meal-name {{item.qty > 0 ? 'meal-name-active' : ''}}">{{item.displayName}}</text>
              <view class="meal-desc-row">
                <text class="meal-desc">{{item.kcal}} {{lbl_kcal}}</text>
                <view wx:if="{{item.qty > 0 && item.sauceOptions.length > 0}}" class="sauce-btn" bindtap="openSaucePicker" data-meal-id="{{item.id}}">
                  <text class="sauce-btn-text">{{item.selectedSauceName ? item.selectedSauceName : lbl_select_sauce}}</text>
                </view>
              </view>
            </view>
            <view class="meal-stepper">
              <view class="stepper-btn stepper-btn-minus {{item.qty === 0 ? 'stepper-btn-disabled' : ''}}" bindtap="decrementMeal" data-meal="{{item}}">
                <text class="stepper-btn-text">−</text>
              </view>
              <text class="stepper-qty">{{item.qty}}</text>
              <view class="stepper-btn stepper-btn-plus" bindtap="incrementMeal" data-meal="{{item}}">
                <text class="stepper-btn-text">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- Snack + Time + Notes + Confirm — show when all meals selected -->
      <block wx:if="{{selectedMealIds.length >= selectedPlan.meals}}">

        <!-- Snack -->
        <view wx:if="{{snackOfDay}}" class="snack-wrap">
          <view class="snack-inner {{snackAdded ? 'snack-inner-added' : ''}}" bindtap="toggleSnack">
            <text class="snack-name">{{snackOfDay}}</text>
            <view class="snack-badge {{snackAdded ? 'snack-badge-added' : ''}}">
              <text>{{snackAdded ? lbl_snack_added : lbl_add_snack}}</text>
            </view>
          </view>
        </view>

        <!-- Time picker -->
        <view class="time-picker">
          <text class="time-picker-label">{{lbl_delivery_time}}</text>
          <picker mode="time" value="{{selectedTime}}" start="07:00" end="20:00" bindchange="onTimeChange">
            <view class="time-picker-display">
              <text class="time-picker-value">{{selectedTime}}</text>
              <text class="time-picker-tap">{{lbl_tap_to_change}}</text>
            </view>
          </picker>
        </view>

        <!-- Notes -->
        <view class="notes-wrap">
          <text class="notes-label">{{lbl_notes}}</text>
          <textarea class="notes-input" placeholder="{{lbl_notes_placeholder}}" value="{{currentNotes}}" bindinput="onNotesInput" auto-height />
        </view>

        <!-- Save & Next combined -->
        <button class="btn-save-next" bindtap="saveAndNext">
          {{isLastDay ? lbl_continue : lbl_save_next}}
        </button>

      </block>



    </block>

  </scroll-view>

  <!-- Sauce Modal -->
  <view wx:if="{{sauceModal.visible}}" class="sauce-modal-mask" bindtap="closeSauceModal">
    <view class="sauce-modal-sheet" catchtap="">
      <view
        wx:for="{{sauceModal.options}}"
        wx:key="id"
        class="sauce-modal-item"
        bindtap="pickSauce"
        data-idx="{{index}}"
      >
        <text class="sauce-modal-item-text">{{item.name}}</text>
      </view>
      <view class="sauce-modal-cancel" bindtap="closeSauceModal">
        <text class="sauce-modal-cancel-text">{{lbl_cancel}}</text>
      </view>
    </view>
  </view>

</view>
