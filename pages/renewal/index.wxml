<view class="container">

  <view class="topbar">
    <view style="width:60rpx;"></view>
    <text class="topbar-title">Renew your plan</text>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <view class="alert-box">
      <view class="alert-top-row">
        <text class="alert-icon">⏰</text>
        <text class="alert-label">{{expired ? 'PLAN EXPIRED' : 'DUE FRIDAY'}}</text>
      </view>
      <text class="alert-text">{{expired ? 'Renew to start receiving meals again' : 'Renew to keep receiving your meals'}}</text>
    </view>

    <text class="section-label">CURRENT PLAN</text>

    <view class="plan-card">
      <view class="plan-card-left">
        <text class="plan-tier">{{planTier}}</text>
        <text class="plan-name">{{planName}}</text>
        <text class="plan-desc">{{planMeals}} meals/day · Mon-Fri</text>
      </view>
      <view class="plan-price-wrap">
        <text class="plan-price">¥{{currentPlanPrice}}</text>
        <text class="plan-price-sub">/wk</text>
      </view>
    </view>

    <view class="buttons">
      <view class="btn-primary" bindtap="keepSameMeals"><text>✓  Renew this plan</text></view>
      <view class="btn-outline" bindtap="changePlan"><text>Choose a different plan</text></view>
    </view>

  </scroll-view>

</view>
