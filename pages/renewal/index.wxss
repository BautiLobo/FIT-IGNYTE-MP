/* pages/renewal/index.wxss */

page { background: #0b0b0c; }

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #0b0b0c;
  overflow: hidden;
}

/* ── TOPBAR ── */
.topbar {
  padding: 80rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #1a1a22;
  display: flex;
  align-items: center;
  background: #0b0b0c;
}
.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: #1a1a22;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.back-arrow { font-size: 40rpx; color: #f3f3f4; line-height: 1; }
.topbar-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 800; color: #f3f3f4; }

/* ── SCROLL ── */
.scroll {
  flex: 1;
  padding: 32rpx 32rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ── ALERT ── */
.alert-box {
  background: #1a0808;
  border: 1rpx solid #3a1010;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 36rpx;
  box-sizing: border-box;
  width: 100%;
}
.alert-top-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.alert-icon { font-size: 28rpx; color: #f87171; }
.alert-label { font-size: 22rpx; color: #f87171; font-weight: 800; letter-spacing: 3rpx; }
.alert-text { font-size: 30rpx; color: #f3f3f4; font-weight: 700; display: block; line-height: 1.4; }

/* ── SECTION LABEL ── */
.section-label {
  font-size: 22rpx;
  color: #beb6b6;
  font-weight: 700;
  letter-spacing: 3rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* ── PLAN CARD ── */
.plan-card {
  background: #13131a;
  border: 1rpx solid #2a2a33;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  width: 100%;
}
.plan-card-left { display: flex; flex-direction: column; gap: 8rpx; }
.plan-tier { font-size: 22rpx; color: #A78BFA; font-weight: 800; letter-spacing: 2rpx; display: block; }
.plan-name { font-size: 44rpx; font-weight: 900; color: #f3f3f4; display: block; }
.plan-desc { font-size: 26rpx; color: #beb6b6; display: block; }
.plan-price-wrap { display: flex; align-items: flex-end; gap: 4rpx; flex-shrink: 0; }
.plan-price { font-size: 56rpx; font-weight: 900; color: #A78BFA; }
.plan-price-sub { font-size: 26rpx; color: #beb6b6; padding-bottom: 10rpx; }

/* ── BUTTONS ── */
.buttons { display: flex; flex-direction: column; gap: 16rpx; width: 100%; box-sizing: border-box; }

button { margin: 0 !important; padding: 0 !important; background: transparent; border: none; }

.btn-primary {
  background: #e8342a;
  border-radius: 20rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

.btn-primary text {
  font-size: 34rpx;
  font-weight: 800;
  color: #fff;
}

.btn-outline {
  background: transparent;
  border: 1rpx solid #2a2a33;
  border-radius: 20rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
}

.btn-outline text {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8342a;
}

.footer {
  padding: 1rpx 200rpx 32rpx;
  box-sizing: border-box;
  width: 100%;
}

.btn-feedback {
  background: transparent;
  border: 1rpx solid #2a2a33;
  border-radius: 20rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
  padding: 100rpx;
  line-height: normal;
}

.btn-feedback::after {
  border: none;
}

.btn-feedback text {
  font-size: 32rpx;
  font-weight: 700;
  color: #9a9aa3;
  text-align: center;
}
