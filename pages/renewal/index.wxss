/* pages/renewal/index.wxss */
.container { display:flex; flex-direction:column; height:100vh; background:#0d0d0d; }
.topbar { background:#111; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:60rpx; }
.back-arrow { font-size:48rpx; color:#E8342A; font-weight:300; }
.topbar-center { flex:1; text-align:center; }
.topbar-title { font-size:32rpx; font-weight:800; color:#fff; display:block; }
.topbar-right { width:60rpx; }
.scroll { flex:1; padding:24rpx 28rpx; }
.alert-box { background:#1a0808; border:1rpx solid #3a0808; border-radius:20rpx; padding:22rpx; margin-bottom:24rpx; }
.alert-label { font-size:22rpx; color:#f87171; font-weight:700; display:block; margin-bottom:6rpx; }
.alert-text { font-size:26rpx; color:#fff; font-weight:700; display:block; }
.current-plan-card { background:#111; border:1rpx solid #1e1e1e; border-radius:20rpx; padding:24rpx; margin-bottom:32rpx; }
.current-plan-info { display:flex; flex-direction:column; gap:6rpx; }
.current-plan-tag { font-size:18rpx; color:#A78BFA; font-weight:700; letter-spacing:2rpx; display:block; }
.current-plan-name { font-size:36rpx; font-weight:800; color:#fff; display:block; }
.current-plan-desc { font-size:24rpx; color:#666; display:block; }
.btn-primary { background:#E8342A; border:none; color:#fff; border-radius:20rpx; padding:26rpx; font-size:30rpx; font-weight:800; width:100%; margin-bottom:16rpx; }
.btn-outline { background:transparent; border:1rpx solid #E8342A; color:#E8342A; border-radius:20rpx; padding:24rpx; font-size:28rpx; font-weight:700; width:100%; margin-bottom:60rpx; }
