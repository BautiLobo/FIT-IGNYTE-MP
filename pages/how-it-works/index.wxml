<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">‹</text>
    </view>
    <text class="topbar-title">{{lbl_title}}</text>
    <view style="width:64rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>
   <view class="scroll-inner">

    <view class="header-block">
    <text class="kicker">{{lbl_kicker}}</text>
    <view class="headline-wrap">
      <text class="headline">{{lbl_headline1}}</text>
      <text class="headline">{{lbl_headline2}}</text>
    </view>
    <text class="intro">{{lbl_intro}}</text>
    <view class="header-divider"></view>
    </view>

    <view class="timeline">

      <view class="step-row">
        <view class="step-marker">
          <text class="step-circle">1</text>
          <view class="step-line"></view>
        </view>
        <view class="step-content">
          <view class="step-head">
            <text class="step-title">{{lbl_step1_title}}</text>
            <text class="step-tag">{{lbl_step1_tag}}</text>
          </view>
          <text class="step-desc">{{lbl_step1_desc}}</text>
        </view>
      </view>

      <view class="step-row">
        <view class="step-marker">
          <text class="step-circle">2</text>
          <view class="step-line"></view>
        </view>
        <view class="step-content">
          <view class="step-head">
            <text class="step-title">{{lbl_step2_title}}</text>
            <text class="step-tag">{{lbl_step2_tag}}</text>
          </view>
          <text class="step-desc">{{lbl_step2_desc}}</text>
        </view>
      </view>

      <view class="step-row">
        <view class="step-marker">
          <text class="step-circle">3</text>
          <view class="step-line"></view>
        </view>
        <view class="step-content">
          <view class="step-head">
            <text class="step-title">{{lbl_step3_title}}</text>
            <text class="step-tag">{{lbl_step3_tag}}</text>
          </view>
          <text class="step-desc">{{lbl_step3_desc}}</text>
        </view>
      </view>

      <view class="step-row step-row-last">
        <view class="step-marker">
          <text class="step-circle">4</text>
        </view>
        <view class="step-content">
          <view class="step-head">
            <text class="step-title">{{lbl_step4_title}}</text>
            <text class="step-tag">{{lbl_step4_tag}}</text>
          </view>
          <text class="step-desc">{{lbl_step4_desc}}</text>
        </view>
      </view>

    </view>

    <view class="btn-wrap">
      <button class="btn-start" bindtap="getStarted">{{lbl_get_started}}</button>
    </view>

   </view>
  </scroll-view>

</view>
