/* pages/how-it-works/index.wxss */

page { background: #0b0b0c; }

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #0b0b0c;
  overflow: hidden;
}

/* ── TOPBAR ── */
.topbar {
  padding: 80rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #1a1a22;
  display: flex;
  align-items: center;
  background: #0b0b0c;
}
.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: #1a1a22;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.back-arrow { font-size: 40rpx; color: #f3f3f4; line-height: 1; }
.topbar-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 800; color: #f3f3f4; }

/* ── SCROLL ── */
.scroll {
  flex: 1;
  display: flex;
  box-sizing: border-box;
  overflow-x: hidden;
}

.scroll-inner {
  display: flex;
  flex-direction: column;
  padding: 32rpx 32rpx 40rpx;
  box-sizing: border-box;
  min-height: 100%;
}

.header-block {
  margin-bottom: 28rpx;
}

.timeline {
  margin-bottom: 24rpx;
}

/* ── HEADER ── */
.kicker {
  font-size: 20rpx;
  color: #e8342a;
  font-weight: 800;
  letter-spacing: 3rpx;
  display: block;
  text-align: center;
}

.headline-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10rpx;
}

.headline {
  font-size: 56rpx;
  font-weight: 800;
  font-style: italic;
  color: #f3f3f4;
  line-height: 1.2;
  display: block;
  text-align: center;
}

.intro {
  font-size: 29rpx;
  color: #9a9aa3;
  line-height: 1.45;
  display: block;
  text-align: center;
  margin: 16rpx auto 0;
  max-width: 580rpx;
}

.header-divider {
  width: 64rpx;
  height: 5rpx;
  background: #e8342a;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

/* ── TIMELINE ── */
.timeline { display: flex; flex-direction: column; }

.step-row {
  display: flex;
  gap: 20rpx;
}

.step-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.step-circle {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: #e8342a;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 66rpx;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(232,52,42,0.4);
}

.step-line {
  width: 3rpx;
  flex: 1;
  background: #4a1a1a;
  margin: 8rpx 0;
}

.step-content {
  flex: 1;
  padding: 16rpx 20rpx 22rpx;
  background: #131318;
  border-radius: 20rpx;
  border: 1rpx solid #1f1f27;
  margin-bottom: 14rpx;
  box-sizing: border-box;
}

.step-row-last .step-content { margin-bottom: 0; }

.step-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.step-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #f3f3f4;
  flex: 1;
}

.step-tag {
  font-size: 19rpx;
  color: #e8342a;
  font-weight: 700;
  letter-spacing: 1rpx;
  flex-shrink: 0;
  background: rgba(232,52,42,0.12);
  padding: 5rpx 12rpx;
  border-radius: 100rpx;
}

.step-desc {
  font-size: 27rpx;
  color: #9a9aa3;
  line-height: 1.45;
  display: block;
}

/* ── BUTTON ── */
.btn-wrap {
  width: 100%;
  margin-top: 12rpx;
}

button { margin: 0 !important; padding: 0 !important; background: transparent; border: none; }

.btn-start {
  background: #e8342a !important;
  border-radius: 24rpx !important;
  height: 96rpx;
  line-height: 96rpx;
  color: #fff !important;
  font-size: 32rpx !important;
  font-weight: 800 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
  box-shadow: 0 8rpx 30rpx rgba(232,52,42,0.35);
}
