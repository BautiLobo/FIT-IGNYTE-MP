/* pages/order-summary/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; }

.topbar { background:#0b0b0c; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:56rpx; height:56rpx; background:#1a1a22; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-arrow { font-size:32rpx; color:#f3f3f4; }
.topbar-title { flex:1; text-align:center; font-size:32rpx; font-weight:800; color:#f3f3f4; }

.scroll { flex:1; padding:20rpx 24rpx; }

.card { background:#13131a; border:1rpx solid #2a2a33; border-radius:20rpx; padding:24rpx; margin-bottom:16rpx; }

.card-label { font-size:20rpx; color:#5d5d65; font-weight:700; letter-spacing:2rpx; text-transform:uppercase; display:block; margin-bottom:14rpx; }

.plan-row { display:flex; justify-content:space-between; align-items:center; }
.plan-name { font-size:30rpx; font-weight:800; color:#f3f3f4; display:block; }
.plan-sub { font-size:22rpx; color:#5d5d65; display:block; margin-top:4rpx; }
.plan-price { font-size:38rpx; font-weight:800; }

.day-label { font-size:22rpx; color:#e8342a; font-weight:700; text-transform:uppercase; letter-spacing:2rpx; display:block; margin:12rpx 0 6rpx; }

.meal-row { display:flex; align-items:center; padding:6rpx 0; }
.meal-slot { font-size:20rpx; color:#5d5d65; font-weight:700; width:40rpx; flex-shrink:0; }
.snack-slot { font-size:20rpx; color:#4ade80; font-weight:700; width:52rpx; flex-shrink:0; }
.meal-name { font-size:26rpx; color:#ccc; flex:1; }
.meal-time { font-size:24rpx; color:#e8342a; font-weight:700; flex-shrink:0; }

.address-card { display:flex; align-items:flex-start; gap:16rpx; }
.address-icon { font-size:36rpx; margin-top:4rpx; }
.address-text { font-size:28rpx; color:#f3f3f4; display:block; margin-top:6rpx; line-height:1.5; }

.price-card { background:#13131a; border:1rpx solid #2a2a33; border-radius:20rpx; padding:24rpx; margin-bottom:24rpx; }
.price-row { display:flex; justify-content:space-between; align-items:center; padding:12rpx 0; }
.price-row-border { border-bottom:1rpx solid #1a1a22; }
.price-label { font-size:26rpx; color:#5d5d65; }
.price-val { font-size:26rpx; color:#ccc; }
.price-total-label { font-size:30rpx; font-weight:800; color:#f3f3f4; }
.price-total-val { font-size:48rpx; font-weight:800; color:#e8342a; }

.btn-submit { display:block; background:#e8342a; border:none; color:#fff; border-radius:100rpx; padding:32rpx 0; font-size:34rpx; font-weight:800; text-align:center; width:100%; margin-bottom:14rpx; }
.btn-disabled { opacity:0.5; }
.hint { font-size:22rpx; color:#5d5d65; text-align:center; display:block; padding-bottom:60rpx; }

.day-header { display:flex; justify-content:space-between; align-items:center; margin:12rpx 0 6rpx; }
.day-time { font-size:24rpx; color:#e8342a; font-weight:700; }

.price-val-strike {
  text-decoration: line-through;
  color: #5d5d65;
}
