<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">{{lbl_title}}</text>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <!-- Plan -->
    <view class="card">
      <text class="card-label">{{lbl_your_plan}}</text>
      <view class="plan-row">
        <view>
          <text class="plan-name">{{selectedPlan.displayName}}</text>
          <text class="plan-sub">{{selectedPlan.meals}} {{lbl_meals_day}}</text>
        </view>
        <text class="plan-price" style="color:#A78BFA;">¥{{selectedPlan.price}}</text>
      </view>
    </view>

    <!-- Meals -->
    <view class="card">
      <view class="card-header-row">
        <text class="card-label">{{lbl_chosen_meals}}</text>
        <view class="btn-edit" bindtap="editMeals"><text>{{lbl_edit}}</text></view>
      </view>
      <view wx:for="{{mealSummary}}" wx:key="day">
        <view class="day-header">
          <text class="day-label">{{item.dayLabel}}</text>
          <text class="day-time">{{item.time}}</text>
        </view>
        <view wx:for="{{item.meals}}" wx:key="slot" wx:for-item="meal" class="meal-row">
          <text class="meal-slot">M{{meal.slot + 1}}</text>
          <text class="meal-name">{{meal.name}}{{meal.sauceName ? ' — ' + meal.sauceName : ''}}</text>
        </view>
        <view wx:if="{{item.snack}}" class="meal-row">
          <text class="snack-slot">SNK</text>
          <text class="meal-name">{{item.snack}}</text>
        </view>
      </view>
    </view>

    <!-- Address -->
    <view class="card address-card">
      <view class="address-icon">📍</view>
      <view class="address-info">
        <text class="card-label">{{lbl_address}}</text>
        <text class="address-text">{{order.address}}{{order.district ? ' · ' + order.district : ''}}</text>
      </view>
      <view class="btn-edit" bindtap="editAddress"><text>{{lbl_edit}}</text></view>
    </view>

    <!-- Price -->
    <view class="price-card">
      <view class="price-row price-row-border">
        <text class="price-label">{{lbl_plan}}</text>
        <text class="price-val {{discount > 0 ? 'price-val-strike' : ''}}">¥{{selectedPlan.price}}</text>
      </view>
      <view class="price-row price-row-border" wx:if="{{discount > 0}}">
        <text class="price-label" style="color:#e8342a;">{{lbl_discount}}</text>
        <text class="price-val" style="color:#e8342a;">-¥{{discount}}</text>
      </view>
      <view class="price-row price-row-border">
        <text class="price-label">{{lbl_delivery}}</text>
        <text class="price-val">¥35</text>
      </view>
      <view class="price-row">
        <text class="price-total-label">{{lbl_total}}</text>
        <text class="price-total-val">¥{{total}}</text>
      </view>
    </view>

    <button class="btn-submit {{submitting ? 'btn-disabled' : ''}}" bindtap="submitOrder" disabled="{{submitting}}">
      {{submitting ? lbl_submitting : (fromRenewal ? lbl_continue_payment : lbl_place_order)}}
    </button>
    <text class="hint">{{fromRenewal ? lbl_renewal_note : lbl_review_note}}</text>

  </scroll-view>

</view>
