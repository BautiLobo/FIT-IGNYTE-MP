<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">Order summary</text>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <!-- Plan -->
    <view class="card">
      <text class="card-label">YOUR PLAN</text>
      <view class="plan-row">
        <view>
          <text class="plan-name">{{selectedPlan.name}}</text>
          <text class="plan-sub">{{selectedPlan.meals}} meal(s)/day · Mon–Fri</text>
        </view>
        <text class="plan-price" style="color:#A78BFA;">¥{{selectedPlan.price}}</text>
      </view>
    </view>

    <!-- Meals -->
    <view class="card">
      <text class="card-label">CHOSEN MEALS</text>
      <view wx:for="{{mealSummary}}" wx:key="day">
        <view class="day-header">
          <text class="day-label">{{item.dayLabel}}</text>
          <text class="day-time">{{item.time}}</text>
        </view>
        <view wx:for="{{item.meals}}" wx:key="slot" wx:for-item="meal" class="meal-row">
          <text class="meal-slot">M{{meal.slot + 1}}</text>
          <text class="meal-name">{{meal.name}}</text>
        </view>
        <view wx:if="{{item.snack}}" class="meal-row">
          <text class="snack-slot">SNK</text>
          <text class="meal-name">{{item.snack}}</text>
        </view>
      </view>
    </view>

    <!-- Address -->
    <view class="card address-card">
      <view class="address-icon">📍</view>
      <view>
        <text class="card-label">ADDRESS</text>
        <text class="address-text">{{order.address}}{{order.district ? ' · ' + order.district : ''}}</text>
      </view>
    </view>

    <!-- Price -->
    <view class="price-card">
      <view class="price-row price-row-border">
        <text class="price-label">Plan</text>
        <text class="price-val price-val-strike">¥{{selectedPlan.price}}</text>
      </view>
      <view class="price-row price-row-border">
        <text class="price-label" style="color:#e8342a;">25% first week discount</text>
        <text class="price-val" style="color:#e8342a;">-¥{{discount}}</text>
      </view>
      <view class="price-row price-row-border">
        <text class="price-label">Delivery (5 days)</text>
        <text class="price-val">¥35</text>
      </view>
      <view class="price-row">
        <text class="price-total-label">Total</text>
        <text class="price-total-val">¥{{total}}</text>
      </view>
    </view>

    <button class="btn-submit {{submitting ? 'btn-disabled' : ''}}" bindtap="submitOrder" disabled="{{submitting}}">
      {{submitting ? 'Submitting...' : 'Place order  →'}}
    </button>
    <text class="hint">We verify your delivery zone and confirm shortly</text>

  </scroll-view>

</view>
