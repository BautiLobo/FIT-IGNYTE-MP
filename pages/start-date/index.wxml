<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">When do you start?</text>
    <view style="width:60rpx;"></view>
  </view>

  <view class="content">

    <view class="center-block">

      <view class="heading-wrap">
        <text class="heading">Choose your start date</text>
        <text class="heading-sub">Mon–Fri delivery · 5 business days</text>
      </view>

      <!-- Date picker -->
      <picker mode="date" value="{{selectedDate}}" start="{{minDate}}" bindchange="onDateChange">
        <view class="date-display">
          <view class="date-left">
            <text class="date-label">START DATE</text>
            <text class="date-value">{{selectedDateFormatted}}</text>
          </view>
          <text class="date-arrow">›</text>
        </view>
      </picker>

      <!-- Expiry info -->
      <view class="expiry-card" wx:if="{{expiryDateFormatted}}">
        <text class="expiry-label">PLAN ENDS</text>
        <text class="expiry-value">{{expiryDateFormatted}}</text>
        <text class="expiry-sub">5 business days</text>
      </view>

      <button class="btn-primary" bindtap="goNext">Continue →</button>

    </view>

  </view>

</view>
