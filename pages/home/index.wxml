<view class="container">

  <!-- Topbar -->
  <view class="topbar">
    <view class="profile-btn" bindtap="goToProfile">
      <text class="profile-icon">P</text>
    </view>
    <image class="topbar-logo" src="/images/logo.png" mode="aspectFit" />
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:else>

      <view wx:for="{{notifications}}" wx:key="id" class="notif-banner">
        <view class="notif-banner-body">
          <text class="notif-banner-title">{{item.title}}</text>
          <text class="notif-banner-message">{{item.message}}</text>
        </view>
        <text class="notif-banner-close" bindtap="dismissNotification" data-id="{{item.id}}">✕</text>
      </view>

      <view class="greeting-row">
        <view>
          <text class="greeting-name">Hi, {{firstName}}</text>
          <text class="greeting-sub plan-color">{{planLabel}}</text>
        </view>
        <view class="status-badge {{isUpcoming ? 'status-badge-upcoming' : ''}}">
          <text class="status-check" wx:if="{{!isUpcoming}}">✓</text>
          <text class="status-text">{{isUpcoming ? 'UPCOMING' : 'ACTIVE'}}</text>
        </view>
      </view>

      <view class="delivery-banner delivery-banner-upcoming" wx:if="{{isUpcoming}}">
        <view class="delivery-banner-body">
          <text class="delivery-banner-title">Your plan starts soon</text>
          <text class="delivery-banner-sub">First delivery on {{startDateFormatted}}</text>
        </view>
      </view>

      <view class="delivery-banner" wx:if="{{!isUpcoming && todayDelivery}}">
        <view class="delivery-banner-icon-wrap">
          <text class="delivery-banner-icon">›</text>
        </view>
        <view class="delivery-banner-body">
          <text class="delivery-banner-title">On the way!</text>
          <text class="delivery-banner-sub">{{todayDelivery.day}} delivery · ETA {{todayDelivery.time}}</text>
        </view>
      </view>

      <view class="meals-card">
        <view class="meals-card-header">
          <text class="meals-card-label">THIS WEEK'S MEALS</text>
          <view class="meals-card-view" bindtap="goToMealSelect">
            <text class="meals-card-view-text">Edit ›</text>
          </view>
        </view>

        <view wx:for="{{weekMeals}}" wx:key="day" class="week-row {{index === weekMeals.length - 1 ? 'week-row-last' : ''}}">
          <text class="week-day {{item.isToday ? 'week-day-today' : ''}}">{{item.dayShort}}</text>
          <view class="week-meal-names">
            <text wx:for="{{item.mealNames}}" wx:for-item="mealName" wx:key="*this" class="week-meal-name">{{mealName}}</text>
          </view>
          <text class="week-time {{item.isToday ? 'week-time-today' : ''}}">{{item.time}}</text>
        </view>
      </view>

<view class="btn-wrap">
        <button class="btn-contact" bindtap="contactUs">Contact FIT IGNYTE</button>
      </view>

    </block>

  </scroll-view>

</view>
