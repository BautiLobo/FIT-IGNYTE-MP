<view class="container">

  <!-- Topbar -->
  <view class="topbar">
    <view class="profile-btn" bindtap="goToProfile">
      <text class="profile-icon">P</text>
    </view>
    <image class="topbar-logo" src="/images/logo.png" mode="aspectFit" />
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:else>

      <view class="greeting-row">
        <view>
          <text class="greeting-name">Hi, {{firstName}}</text>
          <text class="greeting-sub">WEEK {{weekNumber}} · {{planLabel}}</text>
        </view>
        <view class="status-badge">
          <text class="status-check">✓</text>
          <text class="status-text">ACTIVE</text>
        </view>
      </view>

      <view class="delivery-banner" wx:if="{{todayDelivery}}">
        <view class="delivery-banner-icon-wrap">
          <text class="delivery-banner-icon">›</text>
        </view>
        <view class="delivery-banner-body">
          <text class="delivery-banner-title">On the way!</text>
          <text class="delivery-banner-sub">{{todayDelivery.day}} delivery · ETA {{todayDelivery.time}}</text>
        </view>
      </view>

      <view class="meals-card">
        <view class="meals-card-header">
          <text class="meals-card-label">THIS WEEK'S MEALS</text>
          <view class="meals-card-view" bindtap="goToMealSelect">
            <text class="meals-card-view-text">Edit ›</text>
          </view>
        </view>

        <view wx:for="{{weekMeals}}" wx:key="day" class="week-row {{index === weekMeals.length - 1 ? 'week-row-last' : ''}}">
          <text class="week-day {{item.isToday ? 'week-day-today' : ''}}">{{item.dayShort}}</text>
          <text class="week-meal-name">{{item.meal1}}</text>
          <text class="week-time {{item.isToday ? 'week-time-today' : ''}}">{{item.time}}</text>
        </view>
      </view>

      <view class="renewal-card" wx:if="{{showRenewal}}" bindtap="goToRenewal">
        <view class="renewal-body">
          <text class="renewal-title">Renew next week?</text>
          <text class="renewal-sub">Due {{expiryFormatted}} · ¥{{planPrice}}</text>
        </view>
        <view class="renewal-btn">
          <text class="renewal-btn-text">Renew</text>
        </view>
      </view>

      <view class="btn-wrap">
        <button class="btn-contact" bindtap="contactUs">Contact FIT IGNYTE</button>
      </view>

    </block>

  </scroll-view>

</view>
