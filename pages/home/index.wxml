<view class="container">

  <!-- Top Bar -->
  <view class="topbar">
    <view class="brand"><text class="brand-red">FIT</text> IGNYTE</view>
    <view class="profile-btn" bindtap="goToProfile">
      <text class="profile-icon">👤</text>
    </view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:else>

      <!-- Greeting -->
      <view class="greeting-row">
        <view>
          <text class="greeting-name">Hey {{firstName}} 👋</text>
          <text class="greeting-sub">Week {{weekNumber}} · {{client.plan}}</text>
        </view>
        <view class="status-badge">
          <text>Active</text>
        </view>
      </view>

      <!-- Delivery banner — only on delivery days -->
      <view class="delivery-banner" wx:if="{{todayDelivery}}">
        <text class="delivery-banner-icon">🛵</text>
        <view>
          <text class="delivery-banner-title">On its way!</text>
          <text class="delivery-banner-sub">{{todayDelivery.day}} delivery · ETA {{todayDelivery.time}}</text>
        </view>
      </view>

      <!-- This week's meals -->
      <view class="meals-card">
        <view class="meals-card-header">
          <text class="meals-card-label">This week's meals</text>
          <text class="meals-card-edit" bindtap="goToMealSelect">View →</text>
        </view>
        <view wx:for="{{weekMeals}}" wx:key="day" class="week-row {{index === weekMeals.length - 1 ? 'week-row-last' : ''}}">
          <text class="week-day {{item.isToday ? 'week-day-today' : ''}}">{{item.dayShort}}</text>
          <view class="week-meals-info">
            <text class="week-meal-1">{{item.meal1}}</text>
            <text class="week-meal-2" wx:if="{{item.meal2}}">{{item.meal2}}</text>
          </view>
          <view class="snack-mini-badge" wx:if="{{item.snack}}">
            <text>{{item.snack}}</text>
          </view>
          <text class="week-time">{{item.time}}</text>
        </view>
      </view>

      <!-- Renewal alert -->
      <view class="renewal-card" wx:if="{{showRenewal}}" bindtap="goToRenewal">
        <view>
          <text class="renewal-title">Renew next week?</text>
          <text class="renewal-sub">Expires in {{daysLeft}} days · ¥{{client.plan_price}}</text>
        </view>
        <view class="renewal-btn">
          <text>Renew</text>
        </view>
      </view>

      <!-- Contact button -->
      <button class="btn-contact" bindtap="contactUs">
        💬  Contact FIT IGNYTE
      </button>

    </block>

  </scroll-view>

</view>
