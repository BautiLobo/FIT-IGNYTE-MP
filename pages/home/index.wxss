/* pages/home/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0d0d0d; }

/* Top Bar */
.topbar { background:#111; padding:40rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a1a; flex-shrink:0; display:flex; justify-content:space-between; align-items:center; }
.brand { font-size:32rpx; font-weight:800; letter-spacing:4rpx; color:#fff; }
.brand-red { color:#E8342A; }
.profile-btn { width:56rpx; height:56rpx; background:#1a1a1a; border:1rpx solid #2a2a2a; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.profile-icon { font-size:26rpx; }

/* Scroll */
.scroll { flex:1; padding:24rpx 28rpx; }

/* Loading */
.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a2a; border-top-color:#E8342A; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* Greeting */
.greeting-row { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:18rpx; }
.greeting-name { font-size:36rpx; font-weight:800; color:#fff; display:block; }
.greeting-sub { font-size:22rpx; color:#666; display:block; margin-top:4rpx; }
.status-badge { background:#052e16; color:#4ade80; font-size:20rpx; font-weight:700; padding:8rpx 18rpx; border-radius:12rpx; }

/* Delivery Banner */
.delivery-banner { background:#0a2a0a; border:1rpx solid #0f4a0f; border-radius:20rpx; padding:18rpx 22rpx; display:flex; gap:18rpx; align-items:center; margin-bottom:18rpx; }
.delivery-banner-icon { font-size:38rpx; }
.delivery-banner-title { font-size:28rpx; font-weight:700; color:#4ade80; display:block; }
.delivery-banner-sub { font-size:22rpx; color:#888; display:block; margin-top:4rpx; }

/* Meals Card */
.meals-card { background:#111; border:1rpx solid #1e1e1e; border-radius:20rpx; overflow:hidden; margin-bottom:18rpx; }
.meals-card-header { padding:16rpx 24rpx; border-bottom:1rpx solid #1a1a1a; display:flex; justify-content:space-between; align-items:center; }
.meals-card-label { font-size:20rpx; color:#555; text-transform:uppercase; letter-spacing:3rpx; font-weight:700; }
.meals-card-edit { font-size:24rpx; color:#E8342A; font-weight:600; }
.week-row { display:flex; align-items:center; gap:14rpx; padding:14rpx 24rpx; border-bottom:1rpx solid #1a1a1a; }
.week-row-last { border-bottom:none; }
.week-day { font-size:22rpx; font-weight:700; color:#444; width:70rpx; flex-shrink:0; }
.week-day-today { color:#E8342A; }
.week-meals-info { flex:1; }
.week-meal-1 { font-size:24rpx; color:#fff; font-weight:600; display:block; }
.week-meal-2 { font-size:20rpx; color:#aaa; display:block; margin-top:2rpx; }
.snack-mini-badge { background:#0f2a0f; color:#4ade80; font-size:18rpx; font-weight:700; padding:4rpx 12rpx; border-radius:8rpx; flex-shrink:0; }
.week-time { font-size:22rpx; color:#E8342A; font-weight:700; flex-shrink:0; }

/* Renewal Card */
.renewal-card { background:#1a1a1a; border:1rpx solid #2a2a2a; border-radius:20rpx; padding:18rpx 22rpx; display:flex; align-items:center; justify-content:space-between; margin-bottom:18rpx; }
.renewal-title { font-size:26rpx; color:#fff; font-weight:700; display:block; }
.renewal-sub { font-size:22rpx; color:#777; display:block; margin-top:4rpx; }
.renewal-btn { background:transparent; border:1rpx solid #E8342A; color:#E8342A; font-size:22rpx; font-weight:700; padding:10rpx 22rpx; border-radius:14rpx; }

/* Contact Button */
.btn-contact { background:#E8342A; border:none; color:#fff; border-radius:20rpx; padding:26rpx; font-size:30rpx; font-weight:700; width:100%; margin-bottom:60rpx; }
