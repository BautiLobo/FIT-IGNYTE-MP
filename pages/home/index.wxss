/* pages/home/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; overflow:hidden; }

/* ── TOPBAR ── */
.topbar { background:#0b0b0c; padding:80rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; justify-content:space-between; align-items:center; box-sizing:border-box; width:100%; }
.topbar-logo { width:200rpx; height:52rpx; }
.profile-btn { width:60rpx; height:60rpx; background:#1a1a22; border:1rpx solid #2a2a33; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.profile-icon { font-size:28rpx; }

/* ── SCROLL ── */
.scroll { flex:1; padding:24rpx 28rpx; box-sizing:border-box; overflow-x:hidden; }
.loading-wrap { display:flex; justify-content:center; padding:80rpx 0; }
.spinner { width:48rpx; height:48rpx; border:4rpx solid #2a2a33; border-top-color:#e8342a; border-radius:50%; animation:spin 0.8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* ── NOTIFICATION BANNER ── */
.notif-banner { background:linear-gradient(135deg, #2a1416, #1a1014); border:1rpx solid #e8342a; border-left:6rpx solid #e8342a; border-radius:20rpx; padding:24rpx 22rpx; display:flex; align-items:flex-start; gap:18rpx; margin-bottom:18rpx; box-shadow:0 4rpx 20rpx rgba(232,52,42,0.25); }
.notif-banner-icon { font-size:36rpx; flex-shrink:0; line-height:1; margin-top:2rpx; }
.notif-banner-body { flex:1; }
.notif-banner-title { font-size:30rpx; font-weight:900; color:#ffffff; display:block; }
.notif-banner-message { font-size:26rpx; color:#d8c9ca; display:block; margin-top:8rpx; line-height:1.5; }
.notif-banner-close { font-size:28rpx; color:#d8c9ca; flex-shrink:0; padding:0 4rpx; }

/* ── GREETING ── */
.greeting-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:24rpx; overflow:hidden; }
.greeting-name { font-size:52rpx; font-weight:900; font-style:italic; color:#f3f3f4; display:block; }
.greeting-sub { font-size:22rpx; color:#5d5d65; display:block; margin-top:6rpx; letter-spacing:2rpx; }
.plan-color { color:#A78BFA; font-weight:700; }

.status-badge { background:#052e16; border:1rpx solid #166534; border-radius:100rpx; padding:10rpx 16rpx; display:flex; align-items:center; gap:6rpx; flex-shrink:0; }
.status-badge-upcoming { background:#2a1a05; border-color:#92660a; }
.status-badge-upcoming .status-text { color:#eab308; }
.delivery-banner-upcoming { background:#2a1a05; border-color:#92660a; }
.delivery-banner-upcoming .delivery-banner-title { color:#eab308; }
.delivery-banner-upcoming .delivery-banner-sub { color:#a08030; }
.status-check { font-size:20rpx; color:#4ade80; }
.status-text { font-size:20rpx; font-weight:800; color:#4ade80; letter-spacing:2rpx; }

/* ── DELIVERY BANNER ── */
.delivery-banner { background:#052e16; border:1rpx solid #166534; border-radius:20rpx; padding:24rpx; display:flex; gap:20rpx; align-items:center; margin-bottom:20rpx; }
.delivery-banner-icon-wrap { width:64rpx; height:64rpx; background:rgba(74,222,128,0.15); border-radius:16rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.delivery-banner-icon { font-size:32rpx; }
.delivery-banner-title { font-size:30rpx; font-weight:800; color:#4ade80; display:block; }
.delivery-banner-sub { font-size:24rpx; color:#5d7a5d; display:block; margin-top:4rpx; }

/* ── MEALS CARD ── */
.meals-card { background:#13131a; border:1rpx solid #1a1a22; border-radius:20rpx; overflow:hidden; margin-bottom:20rpx; }
.meals-card-header { padding:20rpx 24rpx; border-bottom:1rpx solid #1a1a22; display:flex; justify-content:space-between; align-items:center; }
.meals-card-label { font-size:20rpx; color:#5d5d65; letter-spacing:3rpx; font-weight:700; }
.meals-card-view { display:flex; align-items:center; }
.meals-card-view-text { font-size:26rpx; color:#e8342a; font-weight:700; }
.meals-card-view-arrow { font-size:32rpx; color:#e8342a; font-weight:300; }

.week-row { display:flex; align-items:flex-start; gap:16rpx; padding:22rpx 24rpx; border-bottom:1rpx solid #1a1a22; }
.week-row-last { border-bottom:none; }
.week-day { font-size:24rpx; font-weight:700; color:#5d5d65; width:72rpx; flex-shrink:0; letter-spacing:1rpx; padding-top:4rpx; }
.week-day-today { color:#e8342a; }
.week-meal-photo { display:none; }
.week-meal-names { flex:1; display:flex; flex-direction:column; gap:4rpx; }
.week-meal-name { font-size:28rpx; color:#f3f3f4; font-weight:600; line-height:1.4; display:block; }
.week-time { font-size:28rpx; color:#5d5d65; font-weight:700; flex-shrink:0; margin-left:12rpx; padding-top:4rpx; }
.week-time-today { color:#e8342a; }

/* ── RENEWAL CARD ── */
.renewal-card { background:#13131a; border:1rpx solid #2a2a33; border-radius:20rpx; padding:24rpx; display:flex; align-items:center; justify-content:space-between; margin-bottom:20rpx; }
.renewal-body { flex:1; }
.renewal-title { font-size:28rpx; color:#f3f3f4; font-weight:800; display:block; }
.renewal-sub { font-size:22rpx; color:#5d5d65; display:block; margin-top:6rpx; }
.renewal-btn { background:transparent; border:2rpx solid #e8342a; border-radius:100rpx; padding:14rpx 28rpx; flex-shrink:0; }
.renewal-btn-text { font-size:24rpx; font-weight:700; color:#e8342a; }

/* ── CONTACT ── */
.btn-wrap { width:100%; box-sizing:border-box; margin-bottom:60rpx; }
button { margin:0 !important; padding:0 !important; background:transparent; border:none; }
.btn-contact { background:#13131a !important; border:1rpx solid #1a1a22 !important; color:#6b6b75 !important; border-radius:20rpx !important; height:88rpx; line-height:88rpx; font-size:28rpx !important; font-weight:600 !important; width:100% !important; text-align:center; box-sizing:border-box; display:block; }
