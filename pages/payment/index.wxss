/* pages/payment/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; overflow:hidden; }

/* ── TOPBAR ── */
.topbar { background:#0b0b0c; padding:80rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; align-items:center; }
.back-btn { width:56rpx; height:56rpx; background:#1a1a22; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.back-arrow { font-size:32rpx; color:#f3f3f4; }
.topbar-title { flex:1; text-align:center; font-size:32rpx; font-weight:800; color:#f3f3f4; }
.topbar-lock { font-size:28rpx; width:56rpx; text-align:right; }

/* ── SCROLL ── */
.scroll { flex:1; padding:28rpx 24rpx; box-sizing:border-box; overflow-x:hidden; width:100%; }

/* ── CARD ── */
.card {
  background: #13131a;
  border: 1rpx solid #1a1a22;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  width: 100%;
}

.card-label {
  font-size: 20rpx;
  color: #9f9fa8;
  font-weight: 700;
  letter-spacing: 3rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* ── ROWS ── */
.row { display:flex; justify-content:space-between; align-items:center; padding:14rpx 0; width:100%; box-sizing:border-box; }
.row-border { border-bottom:1rpx solid #1a1a22; }
.row-key { font-size:26rpx; color:#9f9fa8; flex:1; }
.row-key-green { font-size:26rpx; color:#4ade80; font-weight:600; }
.row-val { font-size:26rpx; color:#f3f3f4; font-weight:600; flex-shrink:0; }
.row-val-strike { text-decoration:line-through; color:#9f9fa8; }
.row-val-green { font-size:26rpx; color:#4ade80; font-weight:700; }
.row-total-key { font-size:32rpx; font-weight:800; color:#f3f3f4; }
.row-total-val { font-size:52rpx; font-weight:900; color:#e8342a; }

/* ── SECTION LABEL ── */
.section-label {
  font-size: 20rpx;
  color: #9f9fa8;
  font-weight: 700;
  letter-spacing: 3rpx;
  display: block;
  margin-bottom: 16rpx;
}

/* ── WECHAT PAY ── */
.wechat-pay-btn {
  background: #07C160;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.wechat-pay-left { display:flex; align-items:center; gap:20rpx; }

.wechat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wechat-icon { font-size: 36rpx; }

.wechat-pay-title { font-size: 32rpx; font-weight: 800; color: #fff; display:block; }
.wechat-pay-sub { font-size: 22rpx; color: rgba(255,255,255,0.75); display:block; margin-top:4rpx; }
.wechat-pay-amount { font-size: 44rpx; font-weight: 900; color: #fff; }

/* ── HINT ── */
.pay-hint { font-size:22rpx; color:#9f9fa8; text-align:center; display:block; }
