<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">{{lbl_title}}</text>
    <text class="topbar-lock"></text>
  </view>

  <scroll-view class="scroll" scroll-y>

    <!-- Order Summary -->
    <view class="card">
      <text class="card-label">{{lbl_order_summary}}</text>

      <view class="row row-border">
        <text class="row-key">{{lbl_plan}}</text>
        <text class="row-val">{{selectedPlan.displayName}} · {{selectedPlan.meals}} {{lbl_meals_day}}</text>
      </view>

      <view class="row row-border">
        <text class="row-key">{{lbl_plan_price}}</text>
        <text class="row-val {{discount > 0 ? 'row-val-strike' : ''}}">¥{{selectedPlan.price}}</text>
      </view>

      <view class="row row-border" wx:if="{{discount > 0}}">
        <text class="row-key row-key-green">{{lbl_first_week}}</text>
        <text class="row-val row-val-green">−¥{{discount}}</text>
      </view>

      <view class="row row-border">
        <text class="row-key">{{lbl_delivery}}</text>
        <text class="row-val">¥35</text>
      </view>

      <view class="row">
        <text class="row-total-key">{{lbl_total}}</text>
        <text class="row-total-val">¥{{total}}</text>
      </view>
    </view>

    <!-- Payment method label -->
    <text class="section-label">{{lbl_method}}</text>

    <!-- WeChat Pay -->
    <view class="wechat-pay-btn" bindtap="payNow">
      <view class="wechat-pay-left">
        <view class="wechat-icon-wrap">
          <text class="wechat-icon">💬</text>
        </view>
        <view>
          <text class="wechat-pay-title">{{lbl_wechat_pay}}</text>
          <text class="wechat-pay-sub">{{lbl_tap_to_pay}}</text>
        </view>
      </view>
      <text class="wechat-pay-amount">¥{{total}}</text>
    </view>

    <text class="pay-hint">  {{lbl_renewal_note}}</text>

  </scroll-view>

</view>
