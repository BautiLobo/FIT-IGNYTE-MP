/* pages/edit-profile/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; overflow:hidden; }

.topbar { background:#0b0b0c; padding:80rpx 28rpx 20rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; align-items:center; box-sizing:border-box; width:100%; }
.back-btn { width:60rpx; }
.back-arrow { font-size:48rpx; color:#f3f3f4; font-weight:300; }
.topbar-center { flex:1; text-align:center; }
.topbar-title { font-size:32rpx; font-weight:800; color:#f3f3f4; display:block; }

.scroll { flex:1; padding:28rpx 28rpx; box-sizing:border-box; overflow-x:hidden; }

.field { margin-bottom:36rpx; }

.field-label {
  font-size:20rpx;
  color:#9f9fa8;
  font-weight:700;
  letter-spacing:2rpx;
  display:block;
  margin-bottom:12rpx;
  text-transform:uppercase;
}

.field-input {
  background:#13131a;
  border:1rpx solid #2a2a33;
  border-radius:16rpx;
  padding:30rpx 28rpx;
  font-size:30rpx;
  color:#f3f3f4;
  width:100%;
  box-sizing:border-box;
  min-height:88rpx;
}

.field-input-warning { border-color:#3a1a1a; }

.field-textarea {
  background:#13131a;
  border:1rpx solid #2a2a33;
  border-radius:16rpx;
  padding:30rpx 28rpx;
  font-size:30rpx;
  color:#f3f3f4;
  width:100%;
  box-sizing:border-box;
  height:88rpx;
}

.btn-wrap { padding:10rpx 0 80rpx; width:100%; box-sizing:border-box; }

button { margin:0 !important; padding:0 !important; background:transparent; border:none; }

.btn-primary {
  background:#e8342a !important;
  border-radius:24rpx !important;
  height:100rpx;
  line-height:100rpx;
  font-size:34rpx !important;
  font-weight:800 !important;
  color:#fff !important;
  width:100% !important;
  text-align:center;
  box-sizing:border-box;
  display:block;
}

.btn-disabled { opacity:0.5; }
