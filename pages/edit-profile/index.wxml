<view class="container">

  <!-- Top Bar -->
  <view class="topbar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">‹</text>
    </view>
    <view class="topbar-center">
      <text class="topbar-title">Edit Profile</text>
    </view>
    <text class="save-btn {{saving ? 'save-btn-disabled' : ''}}" bindtap="save">
      {{saving ? 'Saving...' : 'Save'}}
    </text>
  </view>

  <scroll-view class="scroll" scroll-y>

    <view class="field">
      <text class="field-label">Full name</text>
      <input class="field-input" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="field">
      <text class="field-label">Phone / WeChat ID</text>
      <input class="field-input" value="{{form.phone}}" bindinput="onInput" data-field="phone" type="number" />
    </view>

    <view class="field">
      <text class="field-label">District / Area</text>
      <input class="field-input" value="{{form.district}}" bindinput="onInput" data-field="district" />
    </view>

    <view class="field">
      <text class="field-label">Delivery address</text>
      <textarea class="field-textarea" value="{{form.address}}" bindinput="onInput" data-field="address" auto-height />
    </view>

    <view class="field">
      <text class="field-label">Building access</text>
      <input class="field-input" value="{{form.access}}" bindinput="onInput" data-field="access" />
    </view>

    <view class="field">
      <text class="field-label">Allergies / restrictions</text>
      <input class="field-input field-input-warning" value="{{form.allergies}}" bindinput="onInput" data-field="allergies" placeholder="⚠️ e.g. No nuts, gluten-free" />
    </view>

    <view class="field">
      <text class="field-label">Fitness goal</text>
      <input class="field-input" value="{{form.goal}}" bindinput="onInput" data-field="goal" />
    </view>

    <button class="btn-primary" bindtap="save" disabled="{{saving}}">
      {{saving ? 'Saving...' : 'Save changes'}}
    </button>


  </scroll-view>

</view>
