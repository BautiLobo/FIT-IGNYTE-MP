/* pages/loading/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #0d0d0d;
  gap: 0;
}

.logo-wrap {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.logo-fit {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  color: #E8342A;
}

.logo-ignyte {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  color: #ffffff;
}

.tagline {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #444444;
  font-weight: 600;
  margin-bottom: 80rpx;
}

.spinner-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #2a2a2a;
  border-top-color: #E8342A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
