/* pages/plans/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0b0b0c;
  overflow: hidden;
}

.topbar {
  background: #0b0b0c;
  padding: 80rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #1a1a22;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: #1a1a22;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow { font-size: 36rpx; color: #f3f3f4; font-weight: 300; }
.topbar-title { flex: 1; text-align: center; font-size: 32rpx; font-weight: 800; color: #f3f3f4; }

.scroll { flex: 1; padding: 20rpx 24rpx; box-sizing: border-box; overflow-x: hidden; }

.loading-wrap { display: flex; justify-content: center; padding: 80rpx 0; }
.spinner { width: 48rpx; height: 48rpx; border: 4rpx solid #2a2a33; border-top-color: #e8342a; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── LIST HEADER ── */
.list-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 24rpx;
  padding: 4rpx 0;
}

.list-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #f3f3f4;
  display: block;
}

.list-sub {
  font-size: 22rpx;
  color: #9f9fa8;
  display: block;
}

/* ── PLAN CARDS ── */
.plan-wrap { margin-bottom: 16rpx; }

.popular-badge {
  background: #1a0a2a;
  color: #A78BFA;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 6rpx;
}

.plan-card {
  background: #13131a;
  border: 1rpx solid #2a2a33;
  border-left: 4rpx solid;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
}

.plan-card-popular {
  border-color: #A78BFA;
  border-left-color: #A78BFA;
}

.plan-left { display: flex; flex-direction: column; gap: 4rpx; flex: 1; overflow: hidden; }
.plan-category { font-size: 20rpx; font-weight: 700; letter-spacing: 2rpx; text-transform: uppercase; }
.plan-name { font-size: 36rpx; font-weight: 800; color: #f3f3f4; }
.plan-meals { font-size: 24rpx; color: #9f9fa8; }

.plan-right { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; }
.plan-price { font-size: 48rpx; font-weight: 800; }
.plan-period { font-size: 22rpx; color: #5d5d65; }

/* ── HINT ── */
.hint-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 4rpx 60rpx;
}

.hint-line {
  flex: 1;
  height: 1rpx;
  background: #9f9fa8;
  display: block;
}

.hint {
  font-size: 22rpx;
  color: #9f9fa8;
  white-space: nowrap;
}

.plan-kcal { font-size: 20rpx; color:#9f9fa8; display: block; margin-top: 2rpx; }
