<view class="container">

  <view class="topbar">
    <view class="back-btn" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="topbar-title">{{lbl_title}}</text>
    <view style="width:60rpx;"></view>
  </view>

  <scroll-view class="scroll" scroll-y>

    <block wx:if="{{loading}}">
      <view class="loading-wrap"><view class="spinner"></view></view>
    </block>

    <block wx:else>

      <view class="list-header">
        <text class="list-sub">{{lbl_subtitle}}</text>
      </view>

      <view wx:for="{{plans}}" wx:key="id" class="plan-wrap">
        <view class="popular-badge" wx:if="{{item.is_popular}}">
          <text>{{lbl_most_popular}}</text>
        </view>
        <view
          class="plan-card {{item.is_popular ? 'plan-card-popular' : ''}}"
          bindtap="selectPlan"
          data-plan="{{item}}"
          style="border-left-color:{{item.color}};"
        >
          <view class="plan-left">
            <text class="plan-category" style="color:{{item.color}};">{{item.displayTier}}</text>
            <text class="plan-name">{{item.displayName}}</text>
            <text class="plan-meals">{{item.meals}} {{lbl_meals_per_day}}</text>
            <text class="plan-kcal" wx:if="{{item.kcal}}">{{item.lbl_kcal}}</text>
          </view>
          <view class="plan-right">
            <text class="plan-price" style="color:{{item.color}};">¥{{item.price}}</text>
            <text class="plan-period">{{lbl_per_week}}</text>
          </view>
        </view>
      </view>

      <view class="hint-wrap">
        <text class="hint-line"></text>
        <text class="hint">{{lbl_tap_hint}}</text>
        <text class="hint-line"></text>
      </view>

    </block>

  </scroll-view>

</view>
