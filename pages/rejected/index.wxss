/* pages/rejected/index.wxss */

.container { display:flex; flex-direction:column; height:100vh; background:#0b0b0c; }

/* ── TOPBAR ── */
.topbar { padding:80rpx 28rpx 24rpx; border-bottom:1rpx solid #1a1a22; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
.topbar-logo { width:80rpx; height:80rpx; }

/* ── CONTENT ── */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 28rpx 60rpx;
  gap: 24rpx;
}

/* ── HERO ── */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding-bottom: 16rpx;
  text-align: center;
}

.hero-circle {
  width: 160rpx;
  height: 160rpx;
  background: #2a0808;
  border: 3rpx solid #7f1d1d;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.hero-glyph { font-size: 64rpx; }

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #f3f3f4;
  display: block;
  line-height: 1.2;
}

.hero-sub {
  font-size: 26rpx;
  color: #9f9fa8;
  line-height: 1.7;
  display: block;
  padding: 0 8rpx;
}

/* ── INFO CARD ── */
.info-card {
  width: 100%;
  background: #1a0808;
  border: 1rpx solid #7f1d1d;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-icon { font-size: 32rpx; color: #e8342a; flex-shrink: 0; }
.info-text { font-size: 28rpx; font-weight: 700; color: #e8342a; flex: 1; }

/* ── NOTIFY CARD ── */
.notify-card {
  width: 100%;
  background: #13131a;
  border: 1rpx solid #1a1a22;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notify-label {
  font-size: 20rpx;
  color: #9f9fa8;
  font-weight: 700;
  letter-spacing: 3rpx;
  display: block;
}

button { margin:0 !important; padding:0 !important; background:transparent; border:none; }

.btn-notify {
  background: #e8342a !important;
  border-radius: 24rpx !important;
  height: 92rpx;
  line-height: 92rpx;
  color: #fff !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}

/* ── CONTACT ── */
.btn-secondary {
  background: #13131a !important;
  border: 1rpx solid #1a1a22 !important;
  border-radius: 24rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  color: #9f9fa8 !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  text-align: center;
  width: 100% !important;
  box-sizing: border-box;
  display: block;
}
