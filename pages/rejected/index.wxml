<view class="container">

  <view class="topbar">
    <image class="topbar-logo" src="/images/mark.png" mode="aspectFit" />
  </view>

  <view class="content">

    <!-- Hero -->
    <view class="hero">
      <view class="hero-circle">
        <text class="hero-glyph">📍</text>
      </view>
      <text class="hero-title">{{lbl_title}}</text>
      <text class="hero-sub">{{lbl_body}}</text>
    </view>

    <!-- Outside radius info -->
    <view class="info-card">
      <text class="info-icon">⚠</text>
      <text class="info-text">{{lbl_reason}}</text>
    </view>

    <!-- Notify card -->
    <view class="notify-card">
      <text class="notify-label">{{lbl_notify_label}}</text>
      <button class="btn-notify" bindtap="requestNotify">  {{lbl_notify_btn}}</button>
    </view>

    <!-- Contact -->
    <button class="btn-secondary" open-type="contact">  {{lbl_contact}}</button>

  </view>

</view>
