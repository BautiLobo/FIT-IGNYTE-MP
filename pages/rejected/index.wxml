<view class="container">

  <view class="topbar">
    <image class="topbar-logo" src="/images/mark.png" mode="aspectFit" />
  </view>

  <view class="content">

    <!-- Hero -->
    <view class="hero">
      <view class="hero-circle">
        <text class="hero-glyph">📍</text>
      </view>
      <text class="hero-title">We're not in your area yet</text>
      <text class="hero-sub">We don't deliver to your location yet, but we're growing fast!</text>
    </view>

    <!-- Outside radius info -->
    <view class="info-card">
      <text class="info-icon">⚠</text>
      <text class="info-text">Outside our current delivery radius</text>
    </view>

    <!-- Notify card -->
    <view class="notify-card">
      <text class="notify-label">NOTIFY ME WHEN YOU ARRIVE</text>
      <button class="btn-notify" bindtap="requestNotify">🔔  Notify me when available</button>
    </view>

    <!-- Contact -->
    <button class="btn-secondary" bindtap="contactUs">💬  Contact us anyway</button>

  </view>

</view>
