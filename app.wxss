/* app.wxss — FIT IGNYTE global styles */

page {
  background-color: #0b0b0c;
  color: #f3f3f4;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;
  height: 100%;
}

view, text, input, textarea, button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: normal;
  border-radius: 0;
}

button::after {
  border: none;
}

/* ── TYPOGRAPHY ─────────────────────────────── */
.heading-lg {
  font-weight: 800;
  font-size: 40rpx;
  letter-spacing: -1rpx;
  color: #f3f3f4;
}

.heading-md {
  font-weight: 700;
  font-size: 32rpx;
  color: #f3f3f4;
}

.body-lg {
  font-weight: 500;
  font-size: 28rpx;
  line-height: 1.5;
  color: #f3f3f4;
}

.body-sm {
  font-weight: 400;
  font-size: 24rpx;
  color: #5d5d65;
}

.mono-sm {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: #5d5d65;
}

.label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #5d5d65;
}

/* ── BUTTONS ────────────────────────────────── */
.btn-primary {
  display: block;
  background-color: #e8342a;
  color: #f3f3f4;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  font-weight: 700;
  font-size: 32rpx;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-secondary {
  display: block;
  background-color: #2a2a33;
  color: #f3f3f4;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  font-weight: 600;
  font-size: 28rpx;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-outline {
  display: block;
  background-color: transparent;
  color: #e8342a;
  padding: 26rpx 24rpx;
  border-radius: 16rpx;
  font-weight: 600;
  font-size: 28rpx;
  text-align: center;
  border: 2rpx solid #e8342a;
  width: 100%;
}

/* ── CARDS ──────────────────────────────────── */
.card {
  background: #1a1a22;
  border-radius: 16rpx;
  border: 1rpx solid #2a2a33;
  padding: 24rpx;
}

/* ── INPUTS ─────────────────────────────────── */
.input {
  background: #1a1a22;
  border: 1rpx solid #2a2a33;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #f3f3f4;
  width: 100%;
}

.input-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #5d5d65;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 8rpx;
}

/* ── STATUS BADGES ──────────────────────────── */
.badge-active {
  background: #0a2a0a;
  color: #4ade80;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.badge-pending {
  background: #1a1200;
  color: #f59e0b;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.badge-red {
  background: #1a0808;
  color: #e8342a;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #2a0808;
}

/* ── DIVIDER ────────────────────────────────── */
.divider {
  height: 1rpx;
  background: #1a1a22;
  margin: 16rpx 0;
}

/* ── TOPBAR ─────────────────────────────────── */
.topbar {
  background: #0b0b0c;
  padding: 40rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #1a1a22;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.topbar-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #f3f3f4;
  flex: 1;
  text-align: center;
}

.back-btn {
  font-size: 44rpx;
  color: #e8342a;
  font-weight: 300;
  width: 60rpx;
}

/* ── LOADING ────────────────────────────────── */
.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #2a2a33;
  border-top-color: #e8342a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
